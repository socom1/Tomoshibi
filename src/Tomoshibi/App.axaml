<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="using:Tomoshibi"
             xmlns:conv="using:Tomoshibi.Converters"
             xmlns:materialIcons="using:Material.Icons.Avalonia"
             x:Class="Tomoshibi.App"
             RequestedThemeVariant="Dark">

    <Application.DataTemplates>
        <local:ViewLocator />
    </Application.DataTemplates>

    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceInclude Source="avares://Tomoshibi/Styles/Palette.axaml" />
            </ResourceDictionary.MergedDictionaries>
            <conv:CourseColorConverter x:Key="CourseColor" />
            <conv:LowercaseConverter x:Key="Lower" />
        </ResourceDictionary>
    </Application.Resources>

    <Application.Styles>
        <FluentTheme />
        <materialIcons:MaterialIconStyles />
        <StyleInclude Source="avares://Tomoshibi/Styles/Controls.axaml" />
    </Application.Styles>

</Application>
