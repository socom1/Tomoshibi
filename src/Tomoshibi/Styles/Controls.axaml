<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Window background + base font -->
    <Style Selector="Window">
        <Setter Property="Background" Value="{DynamicResource InkBrush}" />
        <Setter Property="FontFamily" Value="{DynamicResource MonoFont}" />
    </Style>

    <!-- Default text -->
    <Style Selector="TextBlock">
        <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
        <Setter Property="FontFamily" Value="{DynamicResource MonoFont}" />
    </Style>

    <!-- Card surface -->
    <Style Selector="Border.card">
        <Setter Property="Background" Value="{DynamicResource SurfaceBrush}" />
        <Setter Property="CornerRadius" Value="{DynamicResource CardRadius}" />
        <Setter Property="Padding" Value="{DynamicResource CardPadding}" />
        <Setter Property="BoxShadow" Value="0 6 20 0 #33000000" />
    </Style>

    <!-- Headings -->
    <Style Selector="TextBlock.h1">
        <Setter Property="FontSize" Value="26" />
        <Setter Property="FontWeight" Value="SemiBold" />
    </Style>

    <!-- Japanese / section labels. Force a CJK-capable font first so all
         characters in the "新しい課題 · new task" pattern render from one
         font and the baselines stay aligned. Trade-off: the Latin part
         loses the mono look, which is fine for these small headings. -->
    <Style Selector="TextBlock.jp">
        <Setter Property="Foreground" Value="{DynamicResource MutedTextBrush}" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="LetterSpacing" Value="0.5" />
        <Setter Property="FontFamily" Value="Hiragino Sans,Yu Gothic UI,Noto Sans CJK JP,sans-serif" />
    </Style>

    <!-- Small captions under stats -->
    <Style Selector="TextBlock.caption">
        <Setter Property="Foreground" Value="{DynamicResource MutedTextBrush}" />
        <Setter Property="FontSize" Value="12" />
    </Style>
    <Style Selector="TextBlock.caption.overdue">
        <Setter Property="Foreground" Value="{DynamicResource SakuraBrush}" />
    </Style>
    <Style Selector="TextBlock.caption.overest">
        <Setter Property="Foreground" Value="{DynamicResource AmberBrush}" />
    </Style>

    <!-- Completed task title -->
    <Style Selector="TextBlock.done">
        <Setter Property="TextDecorations" Value="Strikethrough" />
        <Setter Property="Foreground" Value="{DynamicResource MutedTextBrush}" />
    </Style>

    <!-- The pomodoro clock dims while paused so paused and not-started don't
         look identical. The opacity transition lives inline on the TextBlock
         (its Transitions are already set there for the phase-colour fade). -->
    <Style Selector="TextBlock.timer.paused">
        <Setter Property="Opacity" Value="0.45" />
    </Style>

    <!-- Inputs: consistent shape across TextBox and AutoCompleteBox so the
         Fluent defaults stop fighting the Tokyo Night look. -->
    <Style Selector="TextBox">
        <Setter Property="Background" Value="{DynamicResource SurfaceBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="8" />
        <Setter Property="Padding" Value="12,8" />
        <Setter Property="MinHeight" Value="0" />
        <Setter Property="FontFamily" Value="{DynamicResource MonoFont}" />
        <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
        <Setter Property="Transitions">
            <Transitions>
                <BrushTransition Property="BorderBrush" Duration="0:0:0.15" />
            </Transitions>
        </Setter>
    </Style>
    <Style Selector="TextBox:pointerover /template/ Border#PART_BorderElement">
        <Setter Property="Background" Value="{DynamicResource SurfaceBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource SurfaceHoverBrush}" />
    </Style>
    <Style Selector="TextBox:focus /template/ Border#PART_BorderElement">
        <Setter Property="Background" Value="{DynamicResource SurfaceBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource MatchaBrush}" />
    </Style>

    <!-- Code editor variant — multi-line, monospace, subtle inset look. Used
         by the today task template editor. -->
    <Style Selector="TextBox.code">
        <Setter Property="Background" Value="{DynamicResource InkBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="6" />
        <Setter Property="Padding" Value="12,10" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
        <Setter Property="MinHeight" Value="160" />
    </Style>
    <Style Selector="TextBox.code:pointerover /template/ Border#PART_BorderElement">
        <Setter Property="Background" Value="{DynamicResource InkBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource SurfaceHoverBrush}" />
    </Style>
    <Style Selector="TextBox.code:focus /template/ Border#PART_BorderElement">
        <Setter Property="Background" Value="{DynamicResource InkBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource MatchaBrush}" />
    </Style>

    <!-- Inline text variant — no chrome, sits inside a card like body copy
         (used by the daily intention line). -->
    <Style Selector="TextBox.inline">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="CornerRadius" Value="0" />
    </Style>
    <Style Selector="TextBox.inline /template/ Border#PART_BorderElement">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderBrush" Value="Transparent" />
    </Style>
    <Style Selector="TextBox.inline:pointerover /template/ Border#PART_BorderElement">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderBrush" Value="Transparent" />
    </Style>
    <Style Selector="TextBox.inline:focus /template/ Border#PART_BorderElement">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderBrush" Value="Transparent" />
    </Style>

    <!-- NumericUpDown: kill the spinner buttons (they were huge and ate
         the text width), then carry the same chrome as TextBox so the
         input box itself is visible — surface fill, 1px border, matcha
         on focus. -->
    <Style Selector="NumericUpDown">
        <Setter Property="ShowButtonSpinner" Value="False" />
        <Setter Property="Background" Value="{DynamicResource SurfaceBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="8" />
        <Setter Property="Padding" Value="12,8" />
        <Setter Property="MinHeight" Value="0" />
        <Setter Property="FontFamily" Value="{DynamicResource MonoFont}" />
        <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
        <Setter Property="Transitions">
            <Transitions>
                <BrushTransition Property="BorderBrush" Duration="0:0:0.15" />
            </Transitions>
        </Setter>
    </Style>
    <Style Selector="NumericUpDown:focus-within">
        <Setter Property="BorderBrush" Value="{DynamicResource MatchaBrush}" />
    </Style>

    <!-- Strip the inner TextBox's own chrome so it doesn't render on top
         of NumericUpDown's chrome. -->
    <Style Selector="NumericUpDown /template/ TextBox#PART_TextBox">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="MinHeight" Value="0" />
        <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
    </Style>

    <!-- AutoCompleteBox wraps an inner TextBox; the TextBox style already
         catches the inner one, so we just need to make sure the outer wrapper
         doesn't add its own padding/border on top. -->
    <Style Selector="AutoCompleteBox">
        <Setter Property="FontFamily" Value="{DynamicResource MonoFont}" />
        <Setter Property="MinHeight" Value="0" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Background" Value="Transparent" />
    </Style>

    <!-- CalendarDatePicker has its own Fluent template; tame its border so it
         lines up with the surrounding TextBoxes and stop using the system
         accent for focus. -->
    <Style Selector="CalendarDatePicker">
        <Setter Property="Background" Value="{DynamicResource SurfaceBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="8" />
        <Setter Property="Padding" Value="12,8" />
        <Setter Property="MinHeight" Value="0" />
        <Setter Property="FontFamily" Value="{DynamicResource MonoFont}" />
        <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
        <Setter Property="Transitions">
            <Transitions>
                <BrushTransition Property="BorderBrush" Duration="0:0:0.15" />
            </Transitions>
        </Setter>
    </Style>
    <Style Selector="CalendarDatePicker:pointerover /template/ Border#PART_BorderElement">
        <Setter Property="Background" Value="{DynamicResource SurfaceBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource SurfaceHoverBrush}" />
    </Style>
    <Style Selector="CalendarDatePicker:focus-within /template/ Border#PART_BorderElement">
        <Setter Property="Background" Value="{DynamicResource SurfaceBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource MatchaBrush}" />
    </Style>
    <Style Selector="CalendarDatePicker /template/ TextBox#PART_TextBox">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="MinHeight" Value="0" />
        <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
    </Style>

    <!-- Calendar popup (the CalendarDatePicker dropdown): surface card,
         rounded day cells, matcha selection — instead of the Fluent black. -->
    <Style Selector="Calendar">
        <Setter Property="Background" Value="{DynamicResource SurfaceBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="10" />
        <Setter Property="HeaderBackground" Value="Transparent" />
        <Setter Property="FontFamily" Value="{DynamicResource MonoFont}" />
        <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
    </Style>
    <Style Selector="CalendarItem">
        <Setter Property="Background" Value="{DynamicResource SurfaceBrush}" />
        <Setter Property="HeaderBackground" Value="Transparent" />
        <Setter Property="CornerRadius" Value="10" />
        <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
    </Style>

    <!-- "june 2026" header + the ‹ › arrows -->
    <Style Selector="CalendarItem /template/ Button#PART_HeaderButton">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
        <Setter Property="FontFamily" Value="{DynamicResource MonoFont}" />
        <Setter Property="FontSize" Value="14" />
        <Setter Property="HorizontalContentAlignment" Value="Left" />
    </Style>
    <Style Selector="CalendarItem /template/ Button#PART_HeaderButton:pointerover">
        <Setter Property="Foreground" Value="{DynamicResource MatchaBrush}" />
    </Style>
    <Style Selector="CalendarItem /template/ Button#PART_PreviousButton,
                     CalendarItem /template/ Button#PART_NextButton">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Foreground" Value="{DynamicResource MutedTextBrush}" />
    </Style>
    <Style Selector="CalendarItem /template/ Button#PART_PreviousButton:pointerover,
                     CalendarItem /template/ Button#PART_NextButton:pointerover">
        <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
    </Style>

    <!-- Day cells -->
    <Style Selector="CalendarDayButton">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
        <Setter Property="CornerRadius" Value="6" />
        <Setter Property="FontSize" Value="12" />
        <Setter Property="FontFamily" Value="{DynamicResource MonoFont}" />
        <Setter Property="Margin" Value="1" />
        <Setter Property="MinWidth" Value="34" />
        <Setter Property="MinHeight" Value="30" />
        <Setter Property="Cursor" Value="Hand" />
    </Style>
    <Style Selector="CalendarDayButton:pointerover">
        <Setter Property="Background" Value="{DynamicResource SurfaceHoverBrush}" />
    </Style>
    <Style Selector="CalendarDayButton:selected">
        <Setter Property="Background" Value="{DynamicResource MatchaBrush}" />
        <Setter Property="Foreground" Value="{DynamicResource InkBrush}" />
        <Setter Property="FontWeight" Value="SemiBold" />
    </Style>
    <Style Selector="CalendarDayButton:selected:pointerover">
        <Setter Property="Background" Value="{DynamicResource MatchaDeepBrush}" />
    </Style>
    <Style Selector="CalendarDayButton:today">
        <Setter Property="BorderBrush" Value="{DynamicResource MatchaBrush}" />
        <Setter Property="BorderThickness" Value="1" />
    </Style>
    <Style Selector="CalendarDayButton:inactive">
        <Setter Property="Foreground" Value="{DynamicResource MutedTextBrush}" />
        <Setter Property="Opacity" Value="0.5" />
    </Style>

    <!-- Month/year picker cells (after clicking the header) -->
    <Style Selector="CalendarButton">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
        <Setter Property="CornerRadius" Value="6" />
        <Setter Property="FontFamily" Value="{DynamicResource MonoFont}" />
        <Setter Property="FontSize" Value="12" />
        <Setter Property="Cursor" Value="Hand" />
    </Style>
    <Style Selector="CalendarButton:pointerover">
        <Setter Property="Background" Value="{DynamicResource SurfaceHoverBrush}" />
    </Style>
    <Style Selector="CalendarButton:selected">
        <Setter Property="Background" Value="{DynamicResource MatchaBrush}" />
        <Setter Property="Foreground" Value="{DynamicResource InkBrush}" />
    </Style>

    <!-- TimePicker shares the look — boxed, matcha focus -->
    <Style Selector="TimePicker">
        <Setter Property="Background" Value="{DynamicResource SurfaceBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="8" />
        <Setter Property="MinHeight" Value="0" />
        <Setter Property="FontFamily" Value="{DynamicResource MonoFont}" />
        <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
    </Style>

    <!-- ComboBox: same box as the other inputs, surface popup, no accent blue -->
    <Style Selector="ComboBox">
        <Setter Property="Background" Value="{DynamicResource SurfaceBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="8" />
        <Setter Property="Padding" Value="12,8" />
        <Setter Property="MinHeight" Value="0" />
        <Setter Property="FontFamily" Value="{DynamicResource MonoFont}" />
        <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
    </Style>
    <Style Selector="ComboBox:pointerover /template/ Border#Background">
        <Setter Property="Background" Value="{DynamicResource SurfaceBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource SurfaceHoverBrush}" />
    </Style>
    <Style Selector="ComboBox:focus /template/ Border#Background">
        <Setter Property="Background" Value="{DynamicResource SurfaceBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource MatchaBrush}" />
    </Style>
    <Style Selector="ComboBox /template/ Border#PopupBorder">
        <Setter Property="Background" Value="{DynamicResource SurfaceBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}" />
        <Setter Property="CornerRadius" Value="8" />
    </Style>
    <Style Selector="ComboBoxItem">
        <Setter Property="Padding" Value="10,6" />
        <Setter Property="CornerRadius" Value="6" />
        <Setter Property="FontFamily" Value="{DynamicResource MonoFont}" />
        <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
        <Setter Property="Cursor" Value="Hand" />
    </Style>
    <Style Selector="ComboBoxItem:pointerover /template/ ContentPresenter">
        <Setter Property="Background" Value="{DynamicResource SurfaceHoverBrush}" />
    </Style>
    <Style Selector="ComboBoxItem:selected /template/ ContentPresenter">
        <Setter Property="Background" Value="{DynamicResource SurfaceHoverBrush}" />
        <Setter Property="Foreground" Value="{DynamicResource MatchaBrush}" />
    </Style>

    <!-- CheckBox: matcha tick instead of the Fluent accent blue -->
    <Style Selector="CheckBox /template/ Border#NormalRectangle">
        <Setter Property="Background" Value="{DynamicResource SurfaceBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}" />
        <Setter Property="CornerRadius" Value="4" />
    </Style>
    <Style Selector="CheckBox:pointerover /template/ Border#NormalRectangle">
        <Setter Property="Background" Value="{DynamicResource SurfaceBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource SurfaceHoverBrush}" />
    </Style>
    <Style Selector="CheckBox:checked /template/ Border#NormalRectangle">
        <Setter Property="Background" Value="{DynamicResource MatchaBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource MatchaBrush}" />
    </Style>
    <Style Selector="CheckBox:checked:pointerover /template/ Border#NormalRectangle">
        <Setter Property="Background" Value="{DynamicResource MatchaDeepBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource MatchaDeepBrush}" />
    </Style>
    <Style Selector="CheckBox:checked /template/ Path#CheckGlyph">
        <Setter Property="Fill" Value="{DynamicResource InkBrush}" />
        <Setter Property="Stroke" Value="{DynamicResource InkBrush}" />
    </Style>

    <!-- Agenda entry tints: class blue, due amber, exam sakura -->
    <Style Selector="TextBlock.agclass"><Setter Property="Foreground" Value="{DynamicResource BlueBrush}" /></Style>
    <Style Selector="TextBlock.agdue"><Setter Property="Foreground" Value="{DynamicResource AmberBrush}" /></Style>
    <Style Selector="TextBlock.agexam"><Setter Property="Foreground" Value="{DynamicResource SakuraBrush}" /></Style>
    <!-- Agenda "today" day label gets the accent colour instead of muted -->
    <Style Selector="TextBlock.caption.today"><Setter Property="Foreground" Value="{DynamicResource MatchaBrush}" /></Style>

    <!-- Weak-spot severity dot: amber by default, sakura when severe -->
    <Style Selector="Ellipse.dotsev">
        <Setter Property="Fill" Value="{DynamicResource AmberBrush}" />
    </Style>
    <Style Selector="Ellipse.dotsev.severe">
        <Setter Property="Fill" Value="{DynamicResource SakuraBrush}" />
    </Style>

    <!-- Standing tints: matcha on track, amber close, sakura drifting -->
    <Style Selector="TextBlock.grade">
        <Setter Property="Foreground" Value="{DynamicResource MutedTextBrush}" />
    </Style>
    <Style Selector="TextBlock.grade.ggood">
        <Setter Property="Foreground" Value="{DynamicResource MatchaBrush}" />
    </Style>
    <Style Selector="TextBlock.grade.gwarn">
        <Setter Property="Foreground" Value="{DynamicResource AmberBrush}" />
    </Style>
    <Style Selector="TextBlock.grade.gbad">
        <Setter Property="Foreground" Value="{DynamicResource SakuraBrush}" />
    </Style>
    <Style Selector="Ellipse.ring">
        <Setter Property="Stroke" Value="{DynamicResource MutedTextBrush}" />
    </Style>
    <Style Selector="Ellipse.ring.ggood">
        <Setter Property="Stroke" Value="{DynamicResource MatchaBrush}" />
    </Style>
    <Style Selector="Ellipse.ring.gwarn">
        <Setter Property="Stroke" Value="{DynamicResource AmberBrush}" />
    </Style>
    <Style Selector="Ellipse.ring.gbad">
        <Setter Property="Stroke" Value="{DynamicResource SakuraBrush}" />
    </Style>

    <!-- Subject card: the whole card is clickable, so it hovers like a row -->
    <Style Selector="Border.subjcard">
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Transitions">
            <Transitions>
                <BrushTransition Property="Background" Duration="0:0:0.12" />
            </Transitions>
        </Setter>
    </Style>
    <Style Selector="Border.subjcard:pointerover">
        <Setter Property="Background" Value="{DynamicResource SurfaceHoverBrush}" />
    </Style>

    <!-- Todo row: subtle hover so the dense ticket rows feel interactive -->
    <Style Selector="Border.trow">
        <Setter Property="CornerRadius" Value="6" />
        <Setter Property="Padding" Value="4,3" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Transitions">
            <Transitions>
                <BrushTransition Property="Background" Duration="0:0:0.12" />
            </Transitions>
        </Setter>
    </Style>
    <Style Selector="Border.trow:pointerover">
        <Setter Property="Background" Value="{DynamicResource SurfaceHoverBrush}" />
    </Style>

    <!-- Buttons -->
    <Style Selector="Button">
        <Setter Property="Background" Value="{DynamicResource SurfaceBrush}" />
        <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
        <Setter Property="FontFamily" Value="{DynamicResource MonoFont}" />
        <Setter Property="CornerRadius" Value="10" />
        <Setter Property="Padding" Value="24,10" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}" />
        <Setter Property="Cursor" Value="Hand" />
    </Style>

    <!-- Everything else clickable gets the hand too -->
    <Style Selector="ToggleButton">
        <Setter Property="Cursor" Value="Hand" />
    </Style>
    <Style Selector="CheckBox">
        <Setter Property="Cursor" Value="Hand" />
    </Style>
    <Style Selector="ListBox.tasks ListBoxItem">
        <Setter Property="Cursor" Value="Hand" />
    </Style>
    <Style Selector="Button:pointerover /template/ ContentPresenter">
        <Setter Property="Background" Value="{DynamicResource SurfaceHoverBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}" />
    </Style>

    <!-- Accent (matcha) button -->
    <Style Selector="Button.accent">
        <Setter Property="Background" Value="{DynamicResource MatchaBrush}" />
        <Setter Property="Foreground" Value="{DynamicResource AccentTextBrush}" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="FontWeight" Value="SemiBold" />
    </Style>
    <Style Selector="Button.accent:pointerover /template/ ContentPresenter">
        <Setter Property="Background" Value="{DynamicResource MatchaDeepBrush}" />
    </Style>

    <!-- Borderless icon button (gear, remove) -->
    <Style Selector="Button.icon">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Padding" Value="8,4" />
        <Setter Property="Foreground" Value="{DynamicResource MutedTextBrush}" />
    </Style>
    <Style Selector="Button.icon:pointerover /template/ ContentPresenter">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Foreground" Value="{DynamicResource SakuraBrush}" />
    </Style>

    <!-- Same look for ToggleButton.icon (the </> toggle is one). Without this
         it picks up Fluent's filled :checked background. -->
    <Style Selector="ToggleButton.icon">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Padding" Value="8,4" />
        <Setter Property="Foreground" Value="{DynamicResource MutedTextBrush}" />
    </Style>
    <Style Selector="ToggleButton.icon /template/ ContentPresenter">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderBrush" Value="Transparent" />
    </Style>
    <Style Selector="ToggleButton.icon:pointerover /template/ ContentPresenter">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderBrush" Value="Transparent" />
    </Style>
    <Style Selector="ToggleButton.icon:checked /template/ ContentPresenter">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderBrush" Value="Transparent" />
    </Style>
    <Style Selector="ToggleButton.icon:checked">
        <Setter Property="Foreground" Value="{DynamicResource MatchaBrush}" />
    </Style>
    <Style Selector="ToggleButton.icon:pointerover">
        <Setter Property="Foreground" Value="{DynamicResource SakuraBrush}" />
    </Style>

    <!-- Nav rail: width animates 0 ↔ open so the menu slides in and out. The
         Auto column tracks this width, so the main area glides with it. -->
    <Style Selector="Border.navrail">
        <Setter Property="Width" Value="0" />
        <Setter Property="Transitions">
            <Transitions>
                <DoubleTransition Property="Width" Duration="0:0:0.26" Easing="CubicEaseOut" />
            </Transitions>
        </Setter>
    </Style>
    <Style Selector="Border.navrail.open">
        <Setter Property="Width" Value="208" />
    </Style>

    <!-- Faint section header inside the nav rail -->
    <Style Selector="TextBlock.navsection">
        <Setter Property="Foreground" Value="{DynamicResource MutedTextBrush}" />
        <Setter Property="FontSize" Value="10" />
        <Setter Property="LetterSpacing" Value="1.5" />
        <Setter Property="Opacity" Value="0.7" />
        <Setter Property="Margin" Value="22,16,22,4" />
    </Style>

    <!-- Nav-rail destination button -->
    <Style Selector="Button.nav">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderBrush" Value="Transparent" />
        <Setter Property="BorderThickness" Value="3,0,0,0" />
        <Setter Property="CornerRadius" Value="0" />
        <Setter Property="Padding" Value="19,10" />
        <Setter Property="MinWidth" Value="180" />
        <Setter Property="HorizontalAlignment" Value="Stretch" />
        <Setter Property="HorizontalContentAlignment" Value="Left" />
        <Setter Property="Foreground" Value="{DynamicResource MutedTextBrush}" />
        <Setter Property="FontFamily" Value="{DynamicResource MonoFont}" />
    </Style>
    <Style Selector="Button.nav:pointerover /template/ ContentPresenter">
        <Setter Property="Background" Value="{DynamicResource SurfaceBrush}" />
    </Style>
    <Style Selector="Button.nav.active">
        <Setter Property="BorderBrush" Value="{DynamicResource MatchaBrush}" />
        <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
    </Style>

    <!-- Course tag chip -->
    <Style Selector="Border.tag">
        <Setter Property="Background" Value="{DynamicResource SurfaceHoverBrush}" />
        <Setter Property="CornerRadius" Value="6" />
        <Setter Property="Padding" Value="8,2" />
        <Setter Property="VerticalAlignment" Value="Center" />
    </Style>
    <Style Selector="Border.tag > TextBlock">
        <Setter Property="FontSize" Value="11" />
        <Setter Property="Foreground" Value="{DynamicResource BlueBrush}" />
    </Style>

    <!-- Priority chip: low is muted, high is sakura -->
    <Style Selector="Border.tag.prio > TextBlock">
        <Setter Property="Foreground" Value="{DynamicResource MutedTextBrush}" />
    </Style>
    <Style Selector="Border.tag.prio.high > TextBlock">
        <Setter Property="Foreground" Value="{DynamicResource SakuraBrush}" />
    </Style>

    <!-- Todo status glyph button: ○ backlog / ◐ doing / ● done -->
    <Style Selector="Button.status.doing">
        <Setter Property="Foreground" Value="{DynamicResource BlueBrush}" />
    </Style>
    <Style Selector="Button.status.donestat">
        <Setter Property="Foreground" Value="{DynamicResource MatchaBrush}" />
    </Style>

    <!-- Expand chevron: rotates when open -->
    <Style Selector="ToggleButton.chev">
        <Setter Property="RenderTransformOrigin" Value="0.5,0.5" />
        <Setter Property="Transitions">
            <Transitions>
                <TransformOperationsTransition Property="RenderTransform" Duration="0:0:0.15" />
            </Transitions>
        </Setter>
    </Style>
    <Style Selector="ToggleButton.chev:checked">
        <Setter Property="RenderTransform" Value="rotate(90deg)" />
    </Style>

    <!-- Segmented toggle button (e.g. list / grid view picker) -->
    <Style Selector="Button.seg">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderBrush" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0,0,0,2" />
        <Setter Property="CornerRadius" Value="0" />
        <Setter Property="Padding" Value="10,4" />
        <Setter Property="FontSize" Value="12" />
        <Setter Property="Foreground" Value="{DynamicResource MutedTextBrush}" />
    </Style>
    <Style Selector="Button.seg:pointerover /template/ ContentPresenter">
        <Setter Property="Background" Value="Transparent" />
    </Style>
    <Style Selector="Button.seg:pointerover">
        <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
    </Style>
    <Style Selector="Button.seg.active">
        <Setter Property="BorderBrush" Value="{DynamicResource MatchaBrush}" />
        <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
    </Style>

    <!-- Tasks preview list — click a row to make it the active task; the
         pomodoro then runs that task's study/short/long. -->
    <Style Selector="ListBox.tasks">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Padding" Value="0" />
    </Style>
    <Style Selector="ListBox.tasks ListBoxItem">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderBrush" Value="Transparent" />
        <Setter Property="BorderThickness" Value="3,0,0,0" />
        <Setter Property="CornerRadius" Value="0" />
        <Setter Property="Padding" Value="8,4" />
        <Setter Property="MinHeight" Value="0" />
        <Setter Property="Transitions">
            <Transitions>
                <BrushTransition Property="BorderBrush" Duration="0:0:0.15" />
            </Transitions>
        </Setter>
    </Style>
    <Style Selector="ListBox.tasks ListBoxItem:pointerover /template/ ContentPresenter">
        <Setter Property="Background" Value="{DynamicResource SurfaceHoverBrush}" />
    </Style>
    <Style Selector="ListBox.tasks ListBoxItem:selected /template/ ContentPresenter">
        <Setter Property="Background" Value="Transparent" />
    </Style>
    <Style Selector="ListBox.tasks ListBoxItem:selected">
        <Setter Property="BorderBrush" Value="{DynamicResource MatchaBrush}" />
    </Style>
    <Style Selector="ListBox.tasks ListBoxItem:selected:pointerover /template/ ContentPresenter">
        <Setter Property="Background" Value="{DynamicResource SurfaceHoverBrush}" />
    </Style>

    <!-- Class slot block on the week grid -->
    <Style Selector="Border.slot">
        <Setter Property="Background" Value="#339ECE6A" />
        <Setter Property="BorderBrush" Value="{DynamicResource MatchaBrush}" />
        <Setter Property="BorderThickness" Value="3,0,0,0" />
        <Setter Property="CornerRadius" Value="3" />
        <Setter Property="Margin" Value="2,1" />
        <Setter Property="Transitions">
            <Transitions>
                <BrushTransition Property="Background" Duration="0:0:0.15" />
            </Transitions>
        </Setter>
    </Style>
    <Style Selector="Border.slot:pointerover">
        <Setter Property="Background" Value="#4D9ECE6A" />
    </Style>

    <!-- Music bubble: a floating circle whose equaliser bars dance while
         music plays. The bars idle at fixed heights when silent. -->
    <Style Selector="Button.musicbubble">
        <Setter Property="Width" Value="46" />
        <Setter Property="Height" Value="46" />
        <Setter Property="CornerRadius" Value="23" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="Background" Value="{DynamicResource SurfaceBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="HorizontalContentAlignment" Value="Center" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
    </Style>
    <Style Selector="Button.musicbubble:pointerover /template/ ContentPresenter">
        <Setter Property="Background" Value="{DynamicResource SurfaceHoverBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource MatchaBrush}" />
    </Style>
    <Style Selector="Button.musicbubble.playing">
        <Setter Property="BorderBrush" Value="{DynamicResource MatchaBrush}" />
    </Style>

    <Style Selector="Rectangle.eq">
        <Setter Property="Width" Value="3" />
        <Setter Property="Height" Value="6" />
        <Setter Property="VerticalAlignment" Value="Center" />
        <Setter Property="Fill" Value="{DynamicResource MutedTextBrush}" />
        <Setter Property="RadiusX" Value="1.5" />
        <Setter Property="RadiusY" Value="1.5" />
    </Style>
    <Style Selector="Button.musicbubble.playing Rectangle.eq">
        <Setter Property="Fill" Value="{DynamicResource MatchaBrush}" />
    </Style>
    <Style Selector="Button.musicbubble.playing Rectangle.eq1">
        <Style.Animations>
            <Animation Duration="0:0:0.7" IterationCount="Infinite" PlaybackDirection="Alternate">
                <KeyFrame Cue="0%"><Setter Property="Height" Value="5" /></KeyFrame>
                <KeyFrame Cue="100%"><Setter Property="Height" Value="16" /></KeyFrame>
            </Animation>
        </Style.Animations>
    </Style>
    <Style Selector="Button.musicbubble.playing Rectangle.eq2">
        <Style.Animations>
            <Animation Duration="0:0:0.5" IterationCount="Infinite" PlaybackDirection="Alternate">
                <KeyFrame Cue="0%"><Setter Property="Height" Value="14" /></KeyFrame>
                <KeyFrame Cue="100%"><Setter Property="Height" Value="4" /></KeyFrame>
            </Animation>
        </Style.Animations>
    </Style>
    <Style Selector="Button.musicbubble.playing Rectangle.eq3">
        <Style.Animations>
            <Animation Duration="0:0:0.9" IterationCount="Infinite" PlaybackDirection="Alternate">
                <KeyFrame Cue="0%"><Setter Property="Height" Value="8" /></KeyFrame>
                <KeyFrame Cue="100%"><Setter Property="Height" Value="18" /></KeyFrame>
            </Animation>
        </Style.Animations>
    </Style>
    <Style Selector="Button.musicbubble.playing Rectangle.eq4">
        <Style.Animations>
            <Animation Duration="0:0:0.6" IterationCount="Infinite" PlaybackDirection="Alternate">
                <KeyFrame Cue="0%"><Setter Property="Height" Value="12" /></KeyFrame>
                <KeyFrame Cue="100%"><Setter Property="Height" Value="6" /></KeyFrame>
            </Animation>
        </Style.Animations>
    </Style>

    <!-- Shuffle button lights up matcha when on -->
    <Style Selector="Button.icon.shuffleon">
        <Setter Property="Foreground" Value="{DynamicResource MatchaBrush}" />
    </Style>

    <!-- Launch splash: opacity 1 while booting, fading to 0 (and going
         click-through) once IsBooting flips off. -->
    <Style Selector="Border.splash">
        <Setter Property="Opacity" Value="0" />
        <Setter Property="IsHitTestVisible" Value="False" />
        <Setter Property="Transitions">
            <Transitions>
                <DoubleTransition Property="Opacity" Duration="0:0:0.5" />
            </Transitions>
        </Setter>
    </Style>
    <Style Selector="Border.splash.booting">
        <Setter Property="Opacity" Value="1" />
        <Setter Property="IsHitTestVisible" Value="True" />
    </Style>
    <!-- The lamp + name ease up once on launch -->
    <Style Selector="StackPanel.splashinner">
        <Style.Animations>
            <Animation Duration="0:0:0.7" Easing="CubicEaseOut" FillMode="Forward">
                <KeyFrame Cue="0%">
                    <Setter Property="Opacity" Value="0" />
                    <Setter Property="ScaleTransform.ScaleX" Value="0.82" />
                    <Setter Property="ScaleTransform.ScaleY" Value="0.82" />
                </KeyFrame>
                <KeyFrame Cue="100%">
                    <Setter Property="Opacity" Value="1" />
                    <Setter Property="ScaleTransform.ScaleX" Value="1" />
                    <Setter Property="ScaleTransform.ScaleY" Value="1" />
                </KeyFrame>
            </Animation>
        </Style.Animations>
    </Style>

    <!-- Modal entrance — backdrop fades in; card fades and pops up subtly.
         Avalonia replays Style.Animations every time the style applies
         (which happens when the element becomes visible), so toggling
         IsVisible is enough to re-trigger the animation each open. -->
    <Style Selector="Border.modal-backdrop">
        <Style.Animations>
            <Animation Duration="0:0:0.18" FillMode="Forward">
                <KeyFrame Cue="0%">
                    <Setter Property="Opacity" Value="0" />
                </KeyFrame>
                <KeyFrame Cue="100%">
                    <Setter Property="Opacity" Value="1" />
                </KeyFrame>
            </Animation>
        </Style.Animations>
    </Style>
    <Style Selector="Border.modal-card">
        <Style.Animations>
            <Animation Duration="0:0:0.22" FillMode="Forward" Easing="CubicEaseOut">
                <KeyFrame Cue="0%">
                    <Setter Property="Opacity" Value="0" />
                    <Setter Property="ScaleTransform.ScaleX" Value="0.95" />
                    <Setter Property="ScaleTransform.ScaleY" Value="0.95" />
                </KeyFrame>
                <KeyFrame Cue="100%">
                    <Setter Property="Opacity" Value="1" />
                    <Setter Property="ScaleTransform.ScaleX" Value="1" />
                    <Setter Property="ScaleTransform.ScaleY" Value="1" />
                </KeyFrame>
            </Animation>
        </Style.Animations>
    </Style>

    <!-- Sticky notes: translucent accent cards with a corkboard tilt -->
    <Style Selector="Border.sticky">
        <Setter Property="Width" Value="210" />
        <Setter Property="Height" Value="190" />
        <Setter Property="Margin" Value="10" />
        <Setter Property="Padding" Value="12,10" />
        <Setter Property="CornerRadius" Value="4" />
        <Setter Property="BorderThickness" Value="0,3,0,0" />
        <Setter Property="BoxShadow" Value="0 4 12 0 #44000000" />
    </Style>
    <Style Selector="Border.sticky.samber">
        <Setter Property="Background" Value="#2EE0AF68" />
        <Setter Property="BorderBrush" Value="{DynamicResource AmberBrush}" />
    </Style>
    <Style Selector="Border.sticky.ssakura">
        <Setter Property="Background" Value="#2EF7768E" />
        <Setter Property="BorderBrush" Value="{DynamicResource SakuraBrush}" />
    </Style>
    <Style Selector="Border.sticky.smatcha">
        <Setter Property="Background" Value="#2E9ECE6A" />
        <Setter Property="BorderBrush" Value="{DynamicResource MatchaBrush}" />
    </Style>
    <Style Selector="Border.sticky.sblue">
        <Setter Property="Background" Value="#2E7AA2F7" />
        <Setter Property="BorderBrush" Value="{DynamicResource BlueBrush}" />
    </Style>
    <Style Selector="TextBox.stickytext">
        <Setter Property="FontSize" Value="14" />
    </Style>

    <!-- Sticky colour-picker dots -->
    <Style Selector="Button.dot">
        <Setter Property="Width" Value="14" />
        <Setter Property="Height" Value="14" />
        <Setter Property="CornerRadius" Value="7" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="Margin" Value="0,0,5,0" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Opacity" Value="0.55" />
    </Style>
    <Style Selector="Button.dot:pointerover">
        <Setter Property="Opacity" Value="1" />
    </Style>
    <Style Selector="Button.dot.damber"  > <Setter Property="Background" Value="{DynamicResource AmberBrush}" />  </Style>
    <Style Selector="Button.dot.dsakura" > <Setter Property="Background" Value="{DynamicResource SakuraBrush}" /> </Style>
    <Style Selector="Button.dot.dmatcha" > <Setter Property="Background" Value="{DynamicResource MatchaBrush}" /> </Style>
    <Style Selector="Button.dot.dblue"   > <Setter Property="Background" Value="{DynamicResource BlueBrush}" />   </Style>
    <!-- Keep the dot's own colour on hover (the global hover would grey it) -->
    <Style Selector="Button.dot.damber:pointerover /template/ ContentPresenter">
        <Setter Property="Background" Value="{DynamicResource AmberBrush}" />
    </Style>
    <Style Selector="Button.dot.dsakura:pointerover /template/ ContentPresenter">
        <Setter Property="Background" Value="{DynamicResource SakuraBrush}" />
    </Style>
    <Style Selector="Button.dot.dmatcha:pointerover /template/ ContentPresenter">
        <Setter Property="Background" Value="{DynamicResource MatchaBrush}" />
    </Style>
    <Style Selector="Button.dot.dblue:pointerover /template/ ContentPresenter">
        <Setter Property="Background" Value="{DynamicResource BlueBrush}" />
    </Style>

    <!-- Streak calendar cells: heat-tinted by sessions that day -->
    <Style Selector="Border.cal">
        <Setter Property="Height" Value="36" />
        <Setter Property="Margin" Value="2" />
        <Setter Property="CornerRadius" Value="6" />
        <Setter Property="Background" Value="{DynamicResource SurfaceHoverBrush}" />
    </Style>
    <Style Selector="Border.cal > TextBlock">
        <Setter Property="Foreground" Value="{DynamicResource MutedTextBrush}" />
    </Style>
    <Style Selector="Border.cal.t1">
        <Setter Property="Background" Value="#339ECE6A" />
    </Style>
    <Style Selector="Border.cal.t2">
        <Setter Property="Background" Value="#809ECE6A" />
    </Style>
    <Style Selector="Border.cal.t3">
        <Setter Property="Background" Value="{DynamicResource MatchaBrush}" />
    </Style>
    <Style Selector="Border.cal.t1 > TextBlock, Border.cal.t2 > TextBlock">
        <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
    </Style>
    <Style Selector="Border.cal.t3 > TextBlock">
        <Setter Property="Foreground" Value="{DynamicResource InkBrush}" />
        <Setter Property="FontWeight" Value="SemiBold" />
    </Style>
    <Style Selector="Border.cal.caltoday">
        <Setter Property="BorderBrush" Value="{DynamicResource MatchaBrush}" />
        <Setter Property="BorderThickness" Value="2" />
    </Style>
    <Style Selector="Border.cal.calfuture">
        <Setter Property="Opacity" Value="0.3" />
    </Style>
    <Style Selector="Border.cal.calpad">
        <Setter Property="Background" Value="Transparent" />
    </Style>

    <!-- Flyout surface (settings) -->
    <Style Selector="FlyoutPresenter">
        <Setter Property="Background" Value="{DynamicResource SurfaceBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="12" />
        <Setter Property="Padding" Value="6" />
    </Style>

</Styles>
