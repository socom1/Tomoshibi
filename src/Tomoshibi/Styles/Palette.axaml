<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ============================================================
         Tokyo Night palette
         ============================================================ -->
    <Color x:Key="InkColor">#16161E</Color>
    <Color x:Key="SurfaceColor">#1F2335</Color>
    <Color x:Key="SurfaceHoverColor">#2A2E42</Color>
    <Color x:Key="BorderColor">#2A2E42</Color>
    <!-- Chip fill sits a step above the hover surface so tags keep their
         shape on a hovered card — with the old SurfaceHover fill they melted
         into the row the moment the pointer arrived. -->
    <Color x:Key="ChipColor">#3B4261</Color>
    <Color x:Key="MatchaColor">#9ECE6A</Color>
    <Color x:Key="MatchaDeepColor">#8DBD59</Color>
    <Color x:Key="SakuraColor">#F7768E</Color>
    <Color x:Key="AmberColor">#E0AF68</Color>
    <Color x:Key="BlueColor">#7AA2F7</Color>
    <Color x:Key="TextColor">#C0CAF5</Color>
    <Color x:Key="MutedTextColor">#565F89</Color>
    <!-- Text/icon colour for content sitting on an accent fill (the accent
         button). Dark in the dark theme (accents are light there), light in
         the light theme (accents darken). -->
    <Color x:Key="AccentTextColor">#16161E</Color>

    <!-- Brushes -->
    <SolidColorBrush x:Key="InkBrush" Color="{StaticResource InkColor}" />
    <SolidColorBrush x:Key="SurfaceBrush" Color="{StaticResource SurfaceColor}" />
    <SolidColorBrush x:Key="SurfaceHoverBrush" Color="{StaticResource SurfaceHoverColor}" />
    <SolidColorBrush x:Key="BorderBrush" Color="{StaticResource BorderColor}" />
    <SolidColorBrush x:Key="ChipBrush" Color="{StaticResource ChipColor}" />
    <SolidColorBrush x:Key="MatchaBrush" Color="{StaticResource MatchaColor}" />
    <SolidColorBrush x:Key="MatchaDeepBrush" Color="{StaticResource MatchaDeepColor}" />
    <SolidColorBrush x:Key="SakuraBrush" Color="{StaticResource SakuraColor}" />
    <SolidColorBrush x:Key="AmberBrush" Color="{StaticResource AmberColor}" />
    <SolidColorBrush x:Key="BlueBrush" Color="{StaticResource BlueColor}" />
    <SolidColorBrush x:Key="TextBrush" Color="{StaticResource TextColor}" />
    <SolidColorBrush x:Key="MutedTextBrush" Color="{StaticResource MutedTextColor}" />
    <SolidColorBrush x:Key="AccentTextBrush" Color="{StaticResource AccentTextColor}" />

    <!-- Typography: a coding/monospace family with sensible per-OS fallbacks.
         The CJK families at the end exist so Japanese characters all resolve
         to the same font (per platform) — without them, every kanji and kana
         can hit a different system fallback, which makes baselines jitter. -->
    <FontFamily x:Key="MonoFont">Cascadia Code,JetBrains Mono,Consolas,Menlo,DejaVu Sans Mono,Hiragino Sans,Yu Gothic UI,Noto Sans CJK JP,monospace</FontFamily>

    <!-- A single CJK-capable family for headings/labels that mix Japanese and
         Latin (the "日本語 · english" pattern). Forcing the whole string onto
         one font keeps both scripts on a shared baseline; the mono stack above
         would otherwise split the line between Cascadia (Latin) and a CJK
         fallback (kana/kanji), leaving the Latin part riding higher. -->
    <FontFamily x:Key="JpFont">Hiragino Sans,Yu Gothic UI,Noto Sans CJK JP,sans-serif</FontFamily>

    <!-- Shape / spacing tokens -->
    <CornerRadius x:Key="CardRadius">14</CornerRadius>
    <Thickness x:Key="CardPadding">22</Thickness>

    <!-- Every destination's content column caps at this one width. 960 at the
         13px mono ≈ 120 character columns — a wide terminal window, which is
         the look the app is going for. One token so the pages can't drift
         apart again (they'd crept to 640/760/820/860). The review card's
         reading surface deliberately stays narrower — comfortable reading
         width is a feature there. -->
    <x:Double x:Key="PageMaxWidth">960</x:Double>

</ResourceDictionary>
