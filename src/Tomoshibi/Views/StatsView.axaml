<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Tomoshibi.ViewModels"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             x:Class="Tomoshibi.Views.StatsView"
             x:DataType="vm:StatsViewModel">

    <Grid RowDefinitions="Auto,Auto,*" Margin="28,4,28,28" MaxWidth="640">

        <!-- Page header -->
        <StackPanel Grid.Row="0" Spacing="3" Margin="0,0,0,16">
            <TextBlock Classes="path" Text="~/tomoshibi/stats" />
            <StackPanel Orientation="Horizontal" Spacing="10">
                <TextBlock Text="❯" Classes="prompt" />
                <TextBlock Classes="h1 cjk" VerticalAlignment="Center">
                    <Run Text="記録 · " />
                    <Run Text="{Binding CurrentStreak, Mode=OneWay}" />
                    <Run Text=" day streak" />
                </TextBlock>
            </StackPanel>
        </StackPanel>

        <!-- All-time numbers + 14-day focus sparkline -->
        <Border Grid.Row="1" Classes="card">
            <StackPanel Spacing="16">
                <TextBlock Text="// 累計 · all-time" Classes="jp" />
                <Grid ColumnDefinitions="*,*,*,*">
                    <StackPanel Grid.Column="0" Spacing="2">
                        <TextBlock Text="{Binding BestStreak}" FontSize="26"
                                   Foreground="{DynamicResource MatchaBrush}" />
                        <TextBlock Text="best streak" Classes="caption" />
                    </StackPanel>
                    <StackPanel Grid.Column="1" Spacing="2">
                        <TextBlock Text="{Binding TotalSessions}" FontSize="26"
                                   Foreground="{DynamicResource BlueBrush}" />
                        <TextBlock Text="sessions" Classes="caption" />
                    </StackPanel>
                    <StackPanel Grid.Column="2" Spacing="2">
                        <TextBlock Text="{Binding TotalHours}" FontSize="26"
                                   Foreground="{DynamicResource AmberBrush}" />
                        <TextBlock Text="hours" Classes="caption" />
                    </StackPanel>
                    <StackPanel Grid.Column="3" Spacing="2">
                        <TextBlock Text="{Binding ActiveDays}" FontSize="26"
                                   Foreground="{DynamicResource TextBrush}" />
                        <TextBlock Text="days focused" Classes="caption" />
                    </StackPanel>
                </Grid>

                <!-- Daily focus trend, drawn from block glyphs -->
                <Grid ColumnDefinitions="*,Auto">
                    <TextBlock Grid.Column="0" Text="{Binding Sparkline}"
                               FontFamily="{DynamicResource MonoFont}" FontSize="20"
                               Foreground="{DynamicResource MatchaBrush}"
                               VerticalAlignment="Bottom" />
                    <TextBlock Grid.Column="1" Text="{Binding SparklineSummary}"
                               Classes="caption" Margin="10,0,0,2"
                               VerticalAlignment="Bottom" />
                </Grid>
            </StackPanel>
        </Border>

        <!-- Calendar + focus breakdown, scrollable -->
        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
          <StackPanel>

        <!-- Review stats: retention + heatmap -->
        <Border Classes="card" Margin="0,20,0,0" VerticalAlignment="Top"
                IsVisible="{Binding HasReviewData}">
            <StackPanel Spacing="14">
                <TextBlock Text="// 復習 · review" Classes="jp" />

                <Grid ColumnDefinitions="*,*,*,*">
                    <StackPanel Grid.Column="0" Spacing="2">
                        <TextBlock Text="{Binding RetentionOverall}" FontSize="26"
                                   Foreground="{DynamicResource MatchaBrush}" />
                        <TextBlock Text="retention" Classes="caption" />
                    </StackPanel>
                    <StackPanel Grid.Column="1" Spacing="2">
                        <TextBlock Text="{Binding RetentionMature}" FontSize="26"
                                   Foreground="{DynamicResource BlueBrush}" />
                        <TextBlock Text="mature" Classes="caption" />
                    </StackPanel>
                    <StackPanel Grid.Column="2" Spacing="2">
                        <TextBlock Text="{Binding RetentionYoung}" FontSize="26"
                                   Foreground="{DynamicResource AmberBrush}" />
                        <TextBlock Text="young" Classes="caption" />
                    </StackPanel>
                    <StackPanel Grid.Column="3" Spacing="2">
                        <TextBlock Text="{Binding TotalReviews}" FontSize="26"
                                   Foreground="{DynamicResource TextBrush}" />
                        <TextBlock Text="reviews" Classes="caption" />
                    </StackPanel>
                </Grid>

                <!-- Review heatmap for the shown month -->
                <ItemsControl ItemsSource="{Binding ReviewDays}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <UniformGrid Columns="7" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="vm:CalendarDayViewModel">
                            <Border Classes="cal"
                                    Classes.t1="{Binding IsTier1}"
                                    Classes.t2="{Binding IsTier2}"
                                    Classes.t3="{Binding IsTier3}"
                                    Classes.caltoday="{Binding IsToday}"
                                    Classes.calfuture="{Binding IsFuture}"
                                    Classes.calpad="{Binding IsPlaceholder}"
                                    ToolTip.Tip="{Binding Tooltip}">
                                <TextBlock Text="{Binding Label}" FontSize="11"
                                           HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <TextBlock Classes="caption"
                           Text="○ none · 淡 &lt;20 · 中 20+ · 濃 60+ reviews"
                           HorizontalAlignment="Center" />
                <TextBlock Classes="caption" Text="{Binding ReviewMonthSummary}"
                           Foreground="{DynamicResource MatchaBrush}"
                           HorizontalAlignment="Center" />
            </StackPanel>
        </Border>

        <!-- Weekly retrospective: the last seven days, written up -->
        <Border Classes="card" Margin="0,20,0,0"
                VerticalAlignment="Top"
                IsVisible="{Binding HasWeeklyRetro}">
            <StackPanel Spacing="10">
                <TextBlock Text="// 週報 · weekly retrospective" Classes="jp" />
                <TextBlock Text="{Binding WeeklyRetro}" FontSize="13"
                           TextWrapping="Wrap" LineHeight="22" />
            </StackPanel>
        </Border>

        <!-- Streak calendar -->
        <Border Classes="card" Margin="0,20,0,0"
                VerticalAlignment="Top">
            <StackPanel Spacing="12">

                <!-- Month nav -->
                <Grid ColumnDefinitions="Auto,*,Auto">
                    <Button Grid.Column="0" Classes="icon" Content="‹" FontSize="18"
                            Command="{Binding PrevMonthCommand}"
                            ToolTip.Tip="previous month" />
                    <TextBlock Grid.Column="1" Text="{Binding MonthLabel}"
                               Classes="jp" FontSize="14"
                               HorizontalAlignment="Center" VerticalAlignment="Center" />
                    <Button Grid.Column="2" Classes="icon" Content="›" FontSize="18"
                            Command="{Binding NextMonthCommand}"
                            ToolTip.Tip="next month" />
                </Grid>

                <!-- Weekday header -->
                <UniformGrid Columns="7">
                    <TextBlock Text="mo" Classes="caption" HorizontalAlignment="Center" />
                    <TextBlock Text="tu" Classes="caption" HorizontalAlignment="Center" />
                    <TextBlock Text="we" Classes="caption" HorizontalAlignment="Center" />
                    <TextBlock Text="th" Classes="caption" HorizontalAlignment="Center" />
                    <TextBlock Text="fr" Classes="caption" HorizontalAlignment="Center" />
                    <TextBlock Text="sa" Classes="caption" HorizontalAlignment="Center" />
                    <TextBlock Text="su" Classes="caption" HorizontalAlignment="Center" />
                </UniformGrid>

                <!-- Day cells -->
                <ItemsControl ItemsSource="{Binding Days}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <UniformGrid Columns="7" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="vm:CalendarDayViewModel">
                            <Border Classes="cal"
                                    Classes.t1="{Binding IsTier1}"
                                    Classes.t2="{Binding IsTier2}"
                                    Classes.t3="{Binding IsTier3}"
                                    Classes.caltoday="{Binding IsToday}"
                                    Classes.calfuture="{Binding IsFuture}"
                                    Classes.calpad="{Binding IsPlaceholder}"
                                    ToolTip.Tip="{Binding Tooltip}">
                                <TextBlock Text="{Binding Label}"
                                           FontSize="11"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center" />
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <TextBlock Classes="caption"
                           Text="○ none · 淡 1 · 中 2 · 濃 3+ sessions"
                           HorizontalAlignment="Center" />
                <TextBlock Classes="caption" Text="{Binding MonthSummary}"
                           Foreground="{DynamicResource MatchaBrush}"
                           HorizontalAlignment="Center" />
            </StackPanel>
        </Border>

        <!-- Focus by course (last 7 days) -->
        <Border Classes="card" Margin="0,20,0,0"
                VerticalAlignment="Top"
                IsVisible="{Binding HasFocusByCourse}">
            <StackPanel Spacing="10">
                <TextBlock Text="// 科目別 · focus by course · this week" Classes="jp" />
                <ItemsControl ItemsSource="{Binding FocusByCourse}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="vm:CourseFocusViewModel">
                            <Grid ColumnDefinitions="90,*,46" Margin="0,3,0,0">
                                <TextBlock Grid.Column="0" Text="{Binding Course}"
                                           VerticalAlignment="Center" FontSize="13"
                                           Foreground="{Binding Course, Converter={StaticResource CourseColor}}"
                                           TextTrimming="CharacterEllipsis" />
                                <TextBlock Grid.Column="1" Text="{Binding Bar}"
                                           FontFamily="{DynamicResource MonoFont}" FontSize="13"
                                           VerticalAlignment="Center"
                                           Foreground="{Binding Course, Converter={StaticResource CourseColor}}" />
                                <TextBlock Grid.Column="2" Text="{Binding HoursLabel}"
                                           Classes="caption" HorizontalAlignment="Right"
                                           VerticalAlignment="Center" />
                            </Grid>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </Border>

        <!-- Journal: intention + reflection look-back -->
        <Border Classes="card" Margin="0,20,0,0"
                VerticalAlignment="Top"
                IsVisible="{Binding HasJournal}">
            <StackPanel Spacing="12">
                <TextBlock Text="// 振り返り · journal" Classes="jp" />
                <ItemsControl x:Name="JournalList" ItemsSource="{Binding Journal}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="vm:JournalEntryViewModel">
                            <Border Classes="jentry" Classes.kept="{Binding Kept}"
                                    Classes.highlight="{Binding Highlighted}"
                                    Margin="0,0,0,8">
                                <Grid ColumnDefinitions="84,*">
                                    <TextBlock Grid.Column="0" Text="{Binding DateLabel}"
                                               Classes="caption" FontSize="13" VerticalAlignment="Top"
                                               Classes.today="{Binding IsToday}" />
                                    <StackPanel Grid.Column="1" Spacing="5">
                                        <!-- morning intention -->
                                        <Grid ColumnDefinitions="14,*,Auto" IsVisible="{Binding HasIntention}">
                                            <TextBlock Grid.Column="0" Text="›" VerticalAlignment="Top"
                                                       Foreground="{DynamicResource MatchaBrush}" />
                                            <TextBlock Grid.Column="1" Text="{Binding Intention}"
                                                       FontSize="13" TextWrapping="Wrap" />
                                            <TextBlock Grid.Column="2" Text="達成" FontSize="11"
                                                       Margin="8,1,0,0" VerticalAlignment="Top"
                                                       Foreground="{DynamicResource MatchaBrush}"
                                                       IsVisible="{Binding Kept}" />
                                        </Grid>
                                        <!-- evening reflection -->
                                        <Grid ColumnDefinitions="14,*" IsVisible="{Binding HasReflection}">
                                            <TextBlock Grid.Column="0" Text="↳" Classes="caption"
                                                       VerticalAlignment="Top" />
                                            <TextBlock Grid.Column="1" Text="{Binding Reflection}"
                                                       Classes="caption" TextWrapping="Wrap" />
                                        </Grid>
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </Border>

          </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
