<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Tomoshibi.ViewModels"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             x:Class="Tomoshibi.Views.DashboardView"
             x:DataType="vm:DashboardViewModel">

    <DockPanel>

        <!-- IDE status bar, pinned to the bottom -->
        <Border DockPanel.Dock="Bottom" Classes="statusbar">
            <Grid ColumnDefinitions="Auto,Auto,Auto,*,Auto">
                <TextBlock Grid.Column="0" Classes="statusseg"
                           Foreground="{DynamicResource MatchaBrush}" Text="git:main" />
                <TextBlock Grid.Column="1" Classes="statusseg" Margin="18,0,0,0">
                    <Run Text="streak " />
                    <Run Text="{Binding Today.StreakDays, Mode=OneWay}"
                         Foreground="{DynamicResource AmberBrush}" />
                    <Run Text="d" />
                </TextBlock>
                <TextBlock Grid.Column="2" Classes="statusseg" Margin="18,0,0,0">
                    <Run Text="focus " />
                    <Run Text="{Binding Today.FocusedHours, Mode=OneWay}"
                         Foreground="{DynamicResource BlueBrush}" />
                    <Run Text="h" />
                </TextBlock>
                <TextBlock Grid.Column="4" Classes="statusseg" Text="UTF-8 · LF · mono" />
            </Grid>
        </Border>

        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel Spacing="16" Margin="28,8,28,28" MaxWidth="{StaticResource WidePageMaxWidth}">

                <!-- Editor tab strip -->
                <Grid ColumnDefinitions="Auto,Auto,*" Margin="0,0,0,2">
                    <StackPanel Orientation="Horizontal" Spacing="7" VerticalAlignment="Center">
                        <Ellipse Width="11" Height="11" Fill="{DynamicResource SakuraBrush}" />
                        <Ellipse Width="11" Height="11" Fill="{DynamicResource AmberBrush}" />
                        <Ellipse Width="11" Height="11" Fill="{DynamicResource MatchaBrush}" />
                    </StackPanel>
                    <Border Grid.Column="1" Classes="tab" Margin="16,0,0,0" VerticalAlignment="Bottom">
                        <StackPanel Orientation="Horizontal" Spacing="7">
                            <Ellipse Width="7" Height="7" VerticalAlignment="Center"
                                     Fill="{DynamicResource BlueBrush}" />
                            <TextBlock Text="dashboard.tsx" />
                        </StackPanel>
                    </Border>
                </Grid>

                <!-- Prompt greeting -->
                <StackPanel Spacing="3" Margin="0,4,0,4">
                    <TextBlock Classes="path" Text="~/tomoshibi/dashboard" />
                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <TextBlock Text="❯" Classes="prompt" />
                        <TextBlock Text="{Binding Today.Greeting}" Classes="h1"
                                   VerticalAlignment="Center" />
                        <TextBlock Text="▋" Classes="caret" FontSize="22" />
                    </StackPanel>
                    <TextBlock Classes="caption">
                        <Run Text="# " Foreground="{DynamicResource MutedTextBrush}" />
                        <Run Text="{Binding DateLabel}" />
                    </TextBlock>
                </StackPanel>

                <!-- First-run checklist — ticks off as you set up, pays a few
                     embers per step, and retires once done or skipped. -->
                <Border Classes="card" IsVisible="{Binding ShowGettingStarted}">
                    <StackPanel Spacing="10">
                        <Grid ColumnDefinitions="*,Auto">
                            <TextBlock Text="// はじめまして · getting started" Classes="jp"
                                       VerticalAlignment="Center" />
                            <Button Grid.Column="1" Classes="seg" Content="skip"
                                    Command="{Binding SkipOnboardingCommand}"
                                    ToolTip.Tip="dismiss for good" />
                        </Grid>
                        <TextBlock Classes="caption" FontSize="13" TextWrapping="Wrap"
                                   Text="a few steps to light up the dashboard — each one earns you some embers." />
                        <ItemsControl ItemsSource="{Binding FirstSteps}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="vm:FirstStepViewModel">
                                    <Button Classes="liststep" HorizontalAlignment="Stretch"
                                            Margin="0,0,0,2" Command="{Binding GoCommand}">
                                        <Grid ColumnDefinitions="Auto,*,Auto">
                                            <TextBlock Grid.Column="0" Text="{Binding Glyph}"
                                                       Foreground="{DynamicResource MutedTextBrush}"
                                                       VerticalAlignment="Center" Margin="0,0,10,0" />
                                            <TextBlock Grid.Column="1" Text="{Binding Label}"
                                                       Classes.done="{Binding IsDone}"
                                                       VerticalAlignment="Center" />
                                            <TextBlock Grid.Column="2" Text="{Binding RewardLabel}"
                                                       Classes="caption cjk" VerticalAlignment="Center" />
                                        </Grid>
                                    </Button>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                        <Button Classes="seg" HorizontalAlignment="Left"
                                Content="or try it with example data →"
                                Command="{Binding LoadExampleCommand}" />
                    </StackPanel>
                </Border>

                <!-- Intention -->
                <Border Classes="card">
                    <StackPanel Spacing="8">
                        <Grid ColumnDefinitions="*,Auto">
                            <TextBlock Text="// 今日の狙い · today's intention" Classes="jp"
                                       VerticalAlignment="Center" />
                            <Button Grid.Column="1" Classes="seg" Content="✓ mark kept"
                                    Command="{Binding Today.KeepIntentionCommand}"
                                    IsVisible="{Binding Today.CanKeepIntention}"
                                    ToolTip.Tip="followed it through? bank it for today" />
                            <TextBlock Grid.Column="1" Text="達成 · kept" FontSize="13"
                                       VerticalAlignment="Center"
                                       Foreground="{DynamicResource MatchaBrush}"
                                       IsVisible="{Binding Today.IntentionKept}" />
                        </Grid>
                        <TextBox Classes="inline" Text="{Binding Today.DailyIntention}"
                                 Classes.kept="{Binding Today.IntentionKept}"
                                 Watermark="what do you want to do today?" FontSize="16" />
                        <TextBlock Text="{Binding Today.IntentionHint}" Classes="caption"
                                   IsVisible="{Binding Today.IntentionHint, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />

                        <Border Height="1" Margin="0,4,0,2"
                                Background="{DynamicResource BorderBrush}" />

                        <TextBlock Text="// 振り返り · reflection" Classes="jp" />
                        <TextBox Classes="inline" Text="{Binding Today.DailyReflection}"
                                 Watermark="how did today go?" FontSize="14"
                                 AcceptsReturn="True" TextWrapping="Wrap" />
                    </StackPanel>
                </Border>

                <!-- Stat strip -->
                <Grid ColumnDefinitions="*,*,*,*" >
                    <Border Classes="card" Margin="0,0,6,0">
                        <StackPanel Spacing="2">
                            <TextBlock Text="{Binding Today.CompletedSessions}" FontSize="26"
                                       Foreground="{DynamicResource BlueBrush}" />
                            <TextBlock Text="sessions_today" Classes="caption" />
                        </StackPanel>
                    </Border>
                    <Border Grid.Column="1" Classes="card" Margin="6,0,6,0">
                        <StackPanel Spacing="2">
                            <TextBlock Text="{Binding Today.FocusedHours}" FontSize="26"
                                       Foreground="{DynamicResource AmberBrush}" />
                            <TextBlock Text="hours_today" Classes="caption" />
                        </StackPanel>
                    </Border>
                    <Border Grid.Column="2" Classes="card" Margin="6,0,6,0">
                        <StackPanel Spacing="2">
                            <TextBlock Text="{Binding Today.StreakDays}" FontSize="26"
                                       Foreground="{DynamicResource MatchaBrush}" />
                            <TextBlock Text="streak_days" Classes="caption" />
                        </StackPanel>
                    </Border>
                    <Border Grid.Column="3" Classes="card" Margin="6,0,0,0">
                        <StackPanel Spacing="2">
                            <TextBlock Text="{Binding SessionsThisWeek}" FontSize="26"
                                       Foreground="{DynamicResource TextBrush}" />
                            <TextBlock Text="sessions_week" Classes="caption" />
                        </StackPanel>
                    </Border>
                </Grid>
                <TextBlock Text="{Binding MomentumLabel}" Classes="caption" Margin="2,-6,0,0" />

                <!-- Daily focus goal: today's focused time against the target.
                     Set the target inline; 0 hides this card. -->
                <Border Classes="card" Margin="0,8,0,0" IsVisible="{Binding HasFocusGoal}">
                    <StackPanel Spacing="8">
                        <Grid ColumnDefinitions="*,Auto">
                            <TextBlock Text="{Binding FocusGoalLabel}" Classes="caption"
                                       VerticalAlignment="Center" />
                            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="6"
                                        VerticalAlignment="Center">
                                <TextBlock Text="goal_min" Classes="caption" VerticalAlignment="Center" />
                                <NumericUpDown Value="{Binding FocusGoalMinutes}"
                                               Minimum="0" Maximum="600" Increment="15" FormatString="0"
                                               Width="96" FontSize="12"
                                               HorizontalContentAlignment="Center" />
                            </StackPanel>
                        </Grid>
                        <ProgressBar Value="{Binding FocusGoalFraction}" Minimum="0" Maximum="1"
                                     Height="5" MinHeight="0"
                                     Foreground="{DynamicResource AmberBrush}"
                                     Background="{DynamicResource SurfaceHoverBrush}" />
                    </StackPanel>
                </Border>

                <!-- Review due -->
                <Border Classes="card" IsVisible="{Binding Review.HasDue}">
                    <Grid ColumnDefinitions="*,Auto">
                        <StackPanel Spacing="2" VerticalAlignment="Center">
                            <TextBlock Text="// 復習 · review" Classes="jp" />
                            <TextBlock FontSize="15">
                                <Run Text="{Binding Review.TotalDue, Mode=OneWay}" />
                                <Run Text=" cards due — keep them from slipping" />
                            </TextBlock>
                        </StackPanel>
                        <Button Grid.Column="1" Classes="accent" Content="start review"
                                VerticalAlignment="Center"
                                Command="{Binding StartReviewCommand}" />
                    </Grid>
                </Border>

                <!-- Lower dashboard: two responsive columns. At or above the
                     breakpoint the right zone sits beside the left; below it,
                     it wraps underneath so the page reads as one column. Each
                     zone's width comes from the WrapPanel's own width via the
                     ZoneWidth converter — no code-behind. -->
                <WrapPanel x:Name="DashZones">

                    <!-- Left column: what's next, the week -->
                    <StackPanel Margin="8,0,8,16" Spacing="16"
                                Width="{Binding #DashZones.Bounds.Width, Converter={StaticResource ZoneWidth}}">

                        <!-- Up next -->
                        <Border Classes="card">
                            <StackPanel Spacing="8">
                                <TextBlock Text="// 次は · up next" Classes="jp" />
                                <TextBlock Text="{Binding Today.NextClassLabel}" FontSize="13"
                                           Foreground="{DynamicResource BlueBrush}"
                                           IsVisible="{Binding Today.HasNextClass}" />
                                <TextBlock Text="{Binding Today.DeadlinesLabel}" FontSize="13"
                                           Foreground="{DynamicResource AmberBrush}"
                                           TextWrapping="Wrap"
                                           IsVisible="{Binding Today.HasUpcomingDeadlines}" />
                                <TextBlock FontSize="13" Classes="caption">
                                    <Run Text="{Binding Todo.OpenCount, Mode=OneWay}" />
                                    <Run Text=" backlog · " />
                                    <Run Text="{Binding Todo.DoingCount, Mode=OneWay}" />
                                    <Run Text=" in progress" />
                                </TextBlock>
                                <Button Classes="accent" Content="start focusing"
                                        HorizontalAlignment="Left"
                                        Command="{Binding Today.Pomodoro.ToggleRunCommand}" />
                            </StackPanel>
                        </Border>

                        <!-- This week -->
                        <Border Classes="card" IsVisible="{Binding HasAgenda}">
                            <StackPanel Spacing="10">
                                <TextBlock Text="// 今週 · this week" Classes="jp" />
                                <ItemsControl ItemsSource="{Binding Agenda}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate x:DataType="vm:AgendaDayViewModel">
                                            <Grid ColumnDefinitions="110,*" Margin="0,4,0,0">
                                                <TextBlock Grid.Column="0" Text="{Binding DayLabel}"
                                                           Classes="caption" FontSize="13"
                                                           VerticalAlignment="Top"
                                                           Classes.today="{Binding IsToday}" />
                                                <ItemsControl Grid.Column="1" ItemsSource="{Binding Entries}">
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate x:DataType="vm:AgendaEntryViewModel">
                                                            <TextBlock Text="{Binding Text}" FontSize="13"
                                                                       Margin="0,1,0,1" TextWrapping="Wrap"
                                                                       Classes.agclass="{Binding IsClass}"
                                                                       Classes.agdue="{Binding IsDue}"
                                                                       Classes.agexam="{Binding IsExam}" />
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>
                                            </Grid>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Border>
                    </StackPanel>

                    <!-- Right column: standing, what needs work -->
                    <StackPanel Margin="8,0,8,16" Spacing="16"
                                Width="{Binding #DashZones.Bounds.Width, Converter={StaticResource ZoneWidth}}">

                        <!-- Standing -->
                        <Border Classes="card">
                            <StackPanel Spacing="8">
                                <TextBlock Text="// 成績 · standing" Classes="jp" />
                                <TextBlock Text="{Binding Subjects.GpaLabel}" FontSize="20"
                                           FontWeight="SemiBold" TextWrapping="Wrap" />
                                <TextBlock Text="{Binding Subjects.DegreeLabel}" Classes="caption"
                                           IsVisible="{Binding Subjects.HasDegreeProjection}" />
                                <TextBlock Text="{Binding Subjects.GpaCaption}" Classes="caption"
                                           TextWrapping="Wrap"
                                           IsVisible="{Binding Subjects.GpaCaption, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />
                            </StackPanel>
                        </Border>

                        <!-- Needs work -->
                        <Border Classes="card">
                            <StackPanel Spacing="10">
                                <TextBlock Text="// 要努力 · needs work" Classes="jp" />

                                <ItemsControl ItemsSource="{Binding WeakSpots}" IsVisible="{Binding HasWeakSpots}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate x:DataType="vm:WeakSpotViewModel">
                                            <Border Classes="trow" Margin="0,2,0,0">
                                                <Grid ColumnDefinitions="Auto,*,Auto,Auto">
                                                    <Ellipse Grid.Column="0" Width="8" Height="8"
                                                             VerticalAlignment="Center" Margin="2,0,10,0"
                                                             Fill="{DynamicResource AmberBrush}"
                                                             Classes="dotsev" Classes.severe="{Binding IsSevere}" />
                                                    <StackPanel Grid.Column="1" Spacing="1" VerticalAlignment="Center">
                                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                                            <TextBlock Text="{Binding Name}" FontWeight="SemiBold" />
                                                            <Border Classes="tag" VerticalAlignment="Center"
                                                                    IsVisible="{Binding HasCode}">
                                                                <TextBlock Text="{Binding Code}" Foreground="{Binding Code, Converter={StaticResource CourseColor}}" />
                                                            </Border>
                                                        </StackPanel>
                                                        <TextBlock Text="{Binding Message}" Classes="caption" />
                                                    </StackPanel>
                                                    <Button Grid.Column="2" Content="open" Classes="seg"
                                                            Command="{Binding OpenCommand}" />
                                                    <Button Grid.Column="3" Content="→ today" Classes="seg"
                                                            Command="{Binding SendToTodayCommand}"
                                                            ToolTip.Tip="drop a focus task on today" />
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>

                                <TextBlock Text="{Binding WeakSpotsCaption}" Classes="caption" TextWrapping="Wrap" />
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </WrapPanel>
            </StackPanel>
        </ScrollViewer>
    </DockPanel>
</UserControl>
