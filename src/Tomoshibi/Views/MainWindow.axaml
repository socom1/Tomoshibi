<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:Tomoshibi.ViewModels"
        xmlns:conv="using:Tomoshibi.Converters"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        x:Class="Tomoshibi.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Title="{Binding WindowTitle}"
        Icon="avares://Tomoshibi/Assets/icon.png"
        Width="980" Height="680"
        MinWidth="820" MinHeight="560"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource InkBrush}">

    <Window.Resources>
        <conv:PhaseToBrushConverter x:Key="PhaseToBrush" />
    </Window.Resources>

    <Window.KeyBindings>
        <KeyBinding Gesture="Escape" Command="{Binding CloseCommandPaletteCommand}" />
        <KeyBinding Gesture="Escape" Command="{Binding CloseWhatsNewCommand}" />
        <KeyBinding Gesture="Escape" Command="{Binding CloseWelcomeCommand}" />
        <KeyBinding Gesture="Escape" Command="{Binding Today.Tasks.CancelAddTaskCommand}" />
        <KeyBinding Gesture="Escape" Command="{Binding Todo.CancelModalCommand}" />
        <KeyBinding Gesture="Escape" Command="{Binding Subjects.CancelModalCommand}" />
        <KeyBinding Gesture="Escape" Command="{Binding Subjects.SelectedSubject.CancelAssessmentModalCommand}" />
        <KeyBinding Gesture="Escape" Command="{Binding Subjects.CloseDetailCommand}" />
        <KeyBinding Gesture="Escape" Command="{Binding Timetable.CancelSlotModalCommand}" />
        <KeyBinding Gesture="Escape" Command="{Binding Review.EndReviewCommand}" />
        <KeyBinding Gesture="Escape" Command="{Binding Review.CloseDeckCommand}" />
        <KeyBinding Gesture="Escape" Command="{Binding ExitZenCommand}" />
    </Window.KeyBindings>

    <Design.DataContext>
        <vm:MainWindowViewModel />
    </Design.DataContext>

    <Grid>

    <!-- Normal layout: nav rail | main content. The rail's width animates
         between 0 and its open width via the .open class, so toggling the
         menu slides it in and out; an Auto column lets the main area follow. -->
    <Grid x:Name="NormalLayoutGrid" IsVisible="{Binding !IsZenMode}"
          Classes.blurback="{Binding IsWhatsNewOpen}"
          ColumnDefinitions="Auto,*">

        <!-- ============ Nav rail ============ -->
        <Border Grid.Column="0" Classes="navrail" Classes.open="{Binding IsNavOpen}"
                ClipToBounds="True"
                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,1,0"
                Background="{DynamicResource InkBrush}">
            <DockPanel Margin="0,28,0,20" Width="219" HorizontalAlignment="Left"
                       Grid.IsSharedSizeScope="True">

                <!-- Brand -->
                <TextBlock DockPanel.Dock="Top" Text="灯火 · tomoshibi" Classes="jp"
                           Margin="22,0,22,20" />

                <!-- Footer pinned to the bottom: settings + the wallet. Each
                     label is a single TextBlock (one baseline) so the JP and
                     EN runs don't drift apart across their two fonts. -->
                <StackPanel DockPanel.Dock="Bottom" Spacing="2">
                    <Border Height="1" Margin="22,8,22,8"
                            Background="{DynamicResource BorderBrush}" />
                    <Button Classes="nav" Classes.active="{Binding IsSettingsActive}"
                            Command="{Binding NavigateToSettingsCommand}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="84" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Classes="cjk" Text="設定" />
                            <TextBlock Grid.Column="1" Text="settings" Margin="0"
                                       Foreground="{DynamicResource MutedTextBrush}" />
                        </Grid>
                    </Button>
                    <Button Classes="nav" Classes.active="{Binding IsShopActive}"
                            Command="{Binding NavigateToShopCommand}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="84" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Classes="cjk">
                                <Run Text="火種" Foreground="{DynamicResource AmberBrush}" />
                                <Run Text="{Binding Wallet.Balance}" Foreground="{DynamicResource AmberBrush}" />
                            </TextBlock>
                            <TextBlock Grid.Column="1" Text="shop" Margin="0"
                                       Foreground="{DynamicResource MutedTextBrush}" />
                        </Grid>
                    </Button>
                </StackPanel>

                <!-- Destinations, grouped -->
                <StackPanel Spacing="2">
                    <Button Classes="nav" Classes.active="{Binding IsDashboardActive}"
                            Command="{Binding NavigateToDashboardCommand}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="84" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Classes="cjk" Text="ダッシュ" />
                            <TextBlock Grid.Column="1" Text="dashboard" Margin="0"
                                       Foreground="{DynamicResource MutedTextBrush}" />
                        </Grid>
                    </Button>
                    <Button Classes="nav" Classes.active="{Binding IsTodayActive}"
                            Command="{Binding NavigateToTodayCommand}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="84" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Classes="cjk" Text="ポモドーロ" />
                            <TextBlock Grid.Column="1" Text="pomodoro" Margin="0"
                                       Foreground="{DynamicResource MutedTextBrush}" />
                        </Grid>
                    </Button>

                    <TextBlock Text="計画 · plan" Classes="navsection" />
                    <Button Classes="nav" Classes.active="{Binding IsTimetableActive}"
                            Command="{Binding NavigateToTimetableCommand}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="84" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Classes="cjk" Text="時間割" />
                            <TextBlock Grid.Column="1" Text="timetable" Margin="0"
                                       Foreground="{DynamicResource MutedTextBrush}" />
                        </Grid>
                    </Button>
                    <Button Classes="nav" Classes.active="{Binding IsTodoActive}"
                            Command="{Binding NavigateToTodoCommand}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="84" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Classes="cjk" Text="やること" />
                            <TextBlock Grid.Column="1" Text="todo" Margin="0"
                                       Foreground="{DynamicResource MutedTextBrush}" />
                        </Grid>
                    </Button>
                    <Button Classes="nav" Classes.active="{Binding IsSubjectsActive}"
                            Command="{Binding NavigateToSubjectsCommand}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="84" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Classes="cjk" Text="科目" />
                            <TextBlock Grid.Column="1" Text="subjects" Margin="0"
                                       Foreground="{DynamicResource MutedTextBrush}" />
                        </Grid>
                    </Button>

                    <TextBlock Text="道具 · tools" Classes="navsection" />
                    <Button Classes="nav" Classes.active="{Binding IsStatsActive}"
                            Command="{Binding NavigateToStatsCommand}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="84" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Classes="cjk" Text="記録" />
                            <TextBlock Grid.Column="1" Text="stats" Margin="0"
                                       Foreground="{DynamicResource MutedTextBrush}" />
                        </Grid>
                    </Button>
                    <Button Classes="nav" Classes.active="{Binding IsReviewActive}"
                            Command="{Binding NavigateToReviewCommand}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="84" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Classes="cjk" Text="復習" />
                            <TextBlock Grid.Column="1" Text="review" Margin="0"
                                       Foreground="{DynamicResource MutedTextBrush}" />
                        </Grid>
                    </Button>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- ============ Main area: header + active destination ============ -->
        <Grid Grid.Column="1" RowDefinitions="Auto,*">

            <!-- Shell header: just the nav toggle. Page titles and page
                 actions live inside each destination view. -->
            <Grid Grid.Row="0" Margin="28,28,28,0" ColumnDefinitions="Auto,*">
                <Button Grid.Column="0" Classes="icon" Content="☰" FontSize="18"
                        VerticalAlignment="Top"
                        Command="{Binding ToggleNavCommand}"
                        ToolTip.Tip="menu · メニュー" />
            </Grid>

            <!-- Active destination's view, resolved via ViewLocator. The
                 transitioning variant crossfades when the bound content swaps. -->
            <TransitioningContentControl Grid.Row="1" Content="{Binding ActiveContent}">
                <TransitioningContentControl.PageTransition>
                    <CrossFade Duration="0:0:0.22" />
                </TransitioningContentControl.PageTransition>
            </TransitioningContentControl>
        </Grid>
    </Grid>

    <!-- Add-task modal — semi-transparent backdrop with a centered card.
         Lives at the root so it floats above whichever destination is
         active. DataContext drilled to Today.Tasks so all the form bindings
         stay short. -->
    <Border Classes="modal-backdrop"
            IsVisible="{Binding Today.Tasks.IsAddTaskModalOpen}"
            Classes.open="{Binding Today.Tasks.IsAddTaskModalOpen}"
            Background="#A0000000">
        <Border Classes="card modal-card"
                Width="380" Padding="22"
                HorizontalAlignment="Center" VerticalAlignment="Center"
                DataContext="{Binding Today.Tasks}"
                RenderTransformOrigin="0.5,0.5">
            <Border.RenderTransform>
                <ScaleTransform ScaleX="1" ScaleY="1" />
            </Border.RenderTransform>
            <StackPanel Spacing="14">
                <TextBlock Text="新しい課題 · new task" Classes="jp" />

                <!-- Mode toggle -->
                <Grid ColumnDefinitions="*,*">
                    <Button Grid.Column="0" Classes="seg"
                            Classes.active="{Binding IsSimpleMode}"
                            Content="simple"
                            Command="{Binding ShowSimpleModeCommand}" />
                    <Button Grid.Column="1" Classes="seg"
                            Classes.active="{Binding IsCodeMode}"
                            Content=".code"
                            Command="{Binding ShowCodeModeCommand}" />
                </Grid>

                <!-- Simple form -->
                <StackPanel Spacing="10" IsVisible="{Binding IsSimpleMode}">
                    <TextBox Text="{Binding NewTaskTitle}"
                             Watermark="what's the task?" />
                    <Grid ColumnDefinitions="*,8,*,8,*">
                        <NumericUpDown Grid.Column="0" Value="{Binding NewTaskStudy}"
                                       Watermark="study" Minimum="1" Maximum="240" FormatString="0" />
                        <NumericUpDown Grid.Column="2" Value="{Binding NewTaskShort}"
                                       Watermark="short" Minimum="1" Maximum="60" FormatString="0" />
                        <NumericUpDown Grid.Column="4" Value="{Binding NewTaskLong}"
                                       Watermark="long" Minimum="1" Maximum="120" FormatString="0" />
                    </Grid>
                    <TextBox Text="{Binding NewTaskCourse}" Watermark="course" />
                    <CheckBox IsChecked="{Binding NewTaskDone}" Content="done" />
                </StackPanel>

                <!-- Code form -->
                <TextBox Classes="code" IsVisible="{Binding IsCodeMode}"
                         Text="{Binding NewTaskCode}"
                         Watermark="// title&#x0a;study: 25&#x0a;short: 5&#x0a;course: MATH101"
                         AcceptsReturn="True" TextWrapping="Wrap"
                         MinHeight="140" />

                <Grid ColumnDefinitions="*,*" Margin="0,4,0,0">
                    <Button Grid.Column="0" Content="cancel"
                            HorizontalAlignment="Stretch"
                            Command="{Binding CancelAddTaskCommand}" />
                    <Button Grid.Column="1" Content="add" Classes="accent"
                            HorizontalAlignment="Stretch" Margin="8,0,0,0"
                            Command="{Binding ConfirmAddTaskCommand}" />
                </Grid>
            </StackPanel>
        </Border>
    </Border>

    <!-- Add / edit subject modal — lives at the window root (not inside the
         subjects view) so the backdrop dims the whole app, nav rail and header
         included, like every other modal. Drilled to Subjects for its form. -->
    <Border Classes="modal-backdrop"
            IsVisible="{Binding Subjects.IsModalOpen}"
            Classes.open="{Binding Subjects.IsModalOpen}"
            Background="#A0000000">
        <Border Classes="card modal-card"
                Width="420" Padding="22"
                HorizontalAlignment="Center" VerticalAlignment="Center"
                DataContext="{Binding Subjects}"
                RenderTransformOrigin="0.5,0.5">
            <Border.RenderTransform>
                <ScaleTransform ScaleX="1" ScaleY="1" />
            </Border.RenderTransform>
            <StackPanel Spacing="12">
                <TextBlock Text="{Binding ModalTitle}" Classes="jp" />

                <TextBox Text="{Binding FormName}" Watermark="subject name" />

                <Grid ColumnDefinitions="*,8,110">
                    <AutoCompleteBox Grid.Column="0" Text="{Binding FormCode}"
                                     ItemsSource="{Binding KnownCourses}"
                                     FilterMode="Contains"
                                     Watermark="course code" />
                    <NumericUpDown Grid.Column="2" Value="{Binding FormCredits}"
                                   Watermark="credits"
                                   Minimum="0.5" Maximum="60" Increment="0.5" FormatString="0.#"
                                   ToolTip.Tip="weight toward the overall figure — credit hours / ects / units" />
                </Grid>

                <Grid ColumnDefinitions="*,8,*,8,*">
                    <NumericUpDown Grid.Column="0" Value="{Binding FormYear}"
                                   Watermark="year" Minimum="1" Maximum="10" FormatString="0" />
                    <NumericUpDown Grid.Column="2" Value="{Binding FormSemester}"
                                   Watermark="semester" Minimum="1" Maximum="4" FormatString="0" />
                    <NumericUpDown Grid.Column="4" Value="{Binding FormTarget}"
                                   Watermark="target %" Minimum="1" Maximum="100" FormatString="0.#"
                                   ToolTip.Tip="the grade you're aiming for — drives the outlook" />
                </Grid>

                <NumericUpDown Value="{Binding FormTargetHours}"
                               Watermark="study goal — hours / week"
                               Minimum="0" Maximum="80" Increment="0.5" FormatString="0.#"
                               ToolTip.Tip="weekly study-time goal — tracked against your focus minutes" />

                <TextBox Text="{Binding FormDropRules}"
                         Watermark="drop rules — e.g. quiz: best 8; lab: best 3"
                         ToolTip.Tip="per category, only the best N count" />

                <Grid ColumnDefinitions="*,*" Margin="0,4,0,0">
                    <Button Grid.Column="0" Content="cancel"
                            HorizontalAlignment="Stretch"
                            Command="{Binding CancelModalCommand}" />
                    <Button Grid.Column="1" Content="{Binding ModalAction}" Classes="accent"
                            HorizontalAlignment="Stretch" Margin="8,0,0,0"
                            Command="{Binding ConfirmModalCommand}" />
                </Grid>
            </StackPanel>
        </Border>
    </Border>

    <!-- Add / edit todo modal — root level so the backdrop dims the whole
         app, like the others. Drilled to Todo for its form. -->
    <Border Classes="modal-backdrop"
            IsVisible="{Binding Todo.IsModalOpen}"
            Classes.open="{Binding Todo.IsModalOpen}"
            Background="#A0000000">
        <Border Classes="card modal-card"
                Width="420" Padding="22"
                HorizontalAlignment="Center" VerticalAlignment="Center"
                DataContext="{Binding Todo}"
                RenderTransformOrigin="0.5,0.5">
            <Border.RenderTransform>
                <ScaleTransform ScaleX="1" ScaleY="1" />
            </Border.RenderTransform>
            <StackPanel Spacing="12">
                <TextBlock Text="{Binding ModalTitle}" Classes="jp" />

                <TextBox Text="{Binding FormTitle}" Watermark="what needs doing?" />
                <TextBox Text="{Binding FormDescription}"
                         Watermark="notes — why, where, what 'done' means…"
                         AcceptsReturn="True" TextWrapping="Wrap"
                         MinHeight="84" VerticalContentAlignment="Top" />

                <Grid ColumnDefinitions="*,8,*">
                    <AutoCompleteBox Grid.Column="0" Text="{Binding FormCourse}"
                                     ItemsSource="{Binding KnownCourses}"
                                     FilterMode="Contains" Watermark="course" />
                    <CalendarDatePicker Grid.Column="2" SelectedDate="{Binding FormDue}"
                                        Watermark="due" />
                </Grid>

                <Grid ColumnDefinitions="*,8,*">
                    <ComboBox Grid.Column="0" ItemsSource="{Binding Priorities}"
                              SelectedItem="{Binding FormPriority}"
                              HorizontalAlignment="Stretch">
                        <ComboBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding, Converter={StaticResource Lower}}" />
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>
                    <NumericUpDown Grid.Column="2" Value="{Binding FormEstimate}"
                                   Watermark="est. sessions"
                                   Minimum="1" Maximum="50" FormatString="0" />
                </Grid>

                <Grid ColumnDefinitions="*,*" Margin="0,4,0,0">
                    <Button Grid.Column="0" Content="cancel"
                            HorizontalAlignment="Stretch"
                            Command="{Binding CancelModalCommand}" />
                    <Button Grid.Column="1" Content="{Binding ModalAction}" Classes="accent"
                            HorizontalAlignment="Stretch" Margin="8,0,0,0"
                            Command="{Binding ConfirmModalCommand}" />
                </Grid>
            </StackPanel>
        </Border>
    </Border>

    <!-- Add / edit class-slot modal — root level so the backdrop dims the
         whole app. Opened by the timetable + button or by clicking a class. -->
    <Border Classes="modal-backdrop"
            IsVisible="{Binding Timetable.IsSlotModalOpen}"
            Classes.open="{Binding Timetable.IsSlotModalOpen}"
            Background="#A0000000">
        <Border Classes="card modal-card"
                Width="380" Padding="22"
                HorizontalAlignment="Center" VerticalAlignment="Center"
                DataContext="{Binding Timetable}"
                RenderTransformOrigin="0.5,0.5">
            <Border.RenderTransform>
                <ScaleTransform ScaleX="1" ScaleY="1" />
            </Border.RenderTransform>
            <StackPanel Spacing="12">
                <TextBlock Text="{Binding SlotModalTitle}" Classes="jp" />

                <ComboBox SelectedItem="{Binding NewSlotDay}"
                          ItemsSource="{Binding WeekDays}"
                          HorizontalAlignment="Stretch">
                    <ComboBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding, Converter={StaticResource Lower}}" />
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>

                <!-- start / end as compact HH:MM spinners on their own rows -->
                <Grid ColumnDefinitions="46,*,Auto,*" RowDefinitions="Auto,Auto">
                    <TextBlock Grid.Row="0" Grid.Column="0" Text="start" Classes="key"
                               Margin="0,0,8,0" />
                    <NumericUpDown Grid.Row="0" Grid.Column="1" Value="{Binding StartHour}"
                                   Minimum="0" Maximum="23" Increment="1" FormatString="00"
                                   Margin="0,0,5,0" />
                    <TextBlock Grid.Row="0" Grid.Column="2" Text=":" VerticalAlignment="Center"
                               Margin="0,0,5,0" />
                    <NumericUpDown Grid.Row="0" Grid.Column="3" Value="{Binding StartMinute}"
                                   Minimum="0" Maximum="59" Increment="5" FormatString="00" />

                    <TextBlock Grid.Row="1" Grid.Column="0" Text="end" Classes="key"
                               Margin="0,10,8,0" VerticalAlignment="Center" />
                    <NumericUpDown Grid.Row="1" Grid.Column="1" Value="{Binding EndHour}"
                                   Minimum="0" Maximum="23" Increment="1" FormatString="00"
                                   Margin="0,10,5,0" />
                    <TextBlock Grid.Row="1" Grid.Column="2" Text=":" VerticalAlignment="Center"
                               Margin="0,10,5,0" />
                    <NumericUpDown Grid.Row="1" Grid.Column="3" Value="{Binding EndMinute}"
                                   Minimum="0" Maximum="59" Increment="5" FormatString="00"
                                   Margin="0,10,0,0" />
                </Grid>

                <TextBox Watermark="class name" Text="{Binding NewSlotTitle}" />
                <AutoCompleteBox Watermark="course"
                                 Text="{Binding NewSlotCourse}"
                                 ItemsSource="{Binding KnownCourses}"
                                 FilterMode="Contains" />

                <Grid ColumnDefinitions="*,*" Margin="0,4,0,0">
                    <Button Grid.Column="0" Content="cancel"
                            HorizontalAlignment="Stretch"
                            Command="{Binding CancelSlotModalCommand}" />
                    <Button Grid.Column="1" Content="{Binding SlotFormLabel}" Classes="accent"
                            HorizontalAlignment="Stretch" Margin="8,0,0,0"
                            Command="{Binding AddSlotCommand}" />
                </Grid>
            </StackPanel>
        </Border>
    </Border>

    <!-- Add / edit assessment modal — root level, bound to the open subject. -->
    <Border Classes="modal-backdrop"
            IsVisible="{Binding Subjects.SelectedSubject.IsAssessmentModalOpen, FallbackValue=False}"
            Classes.open="{Binding Subjects.SelectedSubject.IsAssessmentModalOpen, FallbackValue=False}"
            Background="#A0000000">
        <Border Classes="card modal-card"
                Width="360" Padding="22"
                HorizontalAlignment="Center" VerticalAlignment="Center"
                DataContext="{Binding Subjects.SelectedSubject}"
                RenderTransformOrigin="0.5,0.5">
            <Border.RenderTransform>
                <ScaleTransform ScaleX="1" ScaleY="1" />
            </Border.RenderTransform>
            <StackPanel Spacing="12">
                <TextBlock Text="{Binding AssessModalTitle}" Classes="jp" />

                <TextBox Text="{Binding FormAssessTitle}" Watermark="exam, essay, lab…" />

                <Grid ColumnDefinitions="*,8,110">
                    <TextBox Grid.Column="0" Text="{Binding FormAssessCategory}"
                             Watermark="category"
                             ToolTip.Tip="optional — what drop rules target, e.g. quiz" />
                    <NumericUpDown Grid.Column="2" Value="{Binding FormAssessWeight}"
                                   Watermark="weight %" Minimum="0.1" Maximum="100" FormatString="0.#" />
                </Grid>

                <Grid ColumnDefinitions="*,8,*">
                    <NumericUpDown Grid.Column="0" Value="{Binding FormAssessGrade}"
                                   Watermark="grade %" Minimum="0" Maximum="100" FormatString="0.#"
                                   ToolTip.Tip="the real result — leave empty until it lands" />
                    <NumericUpDown Grid.Column="2" Value="{Binding FormAssessWhatIf}"
                                   Watermark="what-if %" Minimum="0" Maximum="100" FormatString="0.#"
                                   BorderBrush="{DynamicResource AmberBrush}"
                                   ToolTip.Tip="hypothetical — planning only, never saved as a real grade" />
                </Grid>

                <CalendarDatePicker SelectedDate="{Binding FormAssessDate}" Watermark="date" />

                <TextBlock Text="what-if is hypothetical — it tints the row amber and feeds the simulated standing, but is never saved as a grade"
                           Classes="caption" TextWrapping="Wrap" />

                <Grid ColumnDefinitions="Auto,*,*" Margin="0,4,0,0">
                    <Button Grid.Column="0" Classes="seg" Content="delete"
                            IsVisible="{Binding IsEditingAssessment}"
                            Command="{Binding DeleteAssessmentCommand}" />
                    <Button Grid.Column="1" Content="cancel"
                            HorizontalAlignment="Stretch" Margin="8,0,0,0"
                            Command="{Binding CancelAssessmentModalCommand}" />
                    <Button Grid.Column="2" Content="save" Classes="accent"
                            HorizontalAlignment="Stretch" Margin="8,0,0,0"
                            Command="{Binding SaveAssessmentCommand}" />
                </Grid>
            </StackPanel>
        </Border>
    </Border>

    <!-- Floating music player: equaliser bubble + slide-up panel -->
    <Border Classes="card musicpanel"
            Width="300" Padding="16"
            HorizontalAlignment="Right" VerticalAlignment="Bottom"
            Margin="0,0,20,84"
            IsVisible="{Binding Music.IsPanelOpen}">
        <StackPanel Spacing="10" DataContext="{Binding Music}">
            <TextBlock Text="音楽 · player" Classes="jp" />

            <TextBlock Text="{Binding TrackLabel}" FontSize="13"
                       TextTrimming="CharacterEllipsis" />

            <StackPanel Orientation="Horizontal" Spacing="6" HorizontalAlignment="Center">
                <Button Classes="icon" Content="⏮" FontSize="16"
                        Command="{Binding PrevTrackCommand}" ToolTip.Tip="previous" />
                <Button Classes="icon" Content="{Binding PlayPauseGlyph}" FontSize="18"
                        Command="{Binding PlayPauseCommand}" ToolTip.Tip="play / pause" />
                <Button Classes="icon" Content="⏭" FontSize="16"
                        Command="{Binding NextTrackCommand}" ToolTip.Tip="next" />
                <Button Classes="icon" Content="⤮" FontSize="14"
                        Classes.shuffleon="{Binding Shuffle}"
                        Command="{Binding ToggleShuffleCommand}" ToolTip.Tip="shuffle" />
                <Button Classes="icon" Content="◼" FontSize="12"
                        Command="{Binding StopPlaybackCommand}" ToolTip.Tip="stop" />
            </StackPanel>

            <Grid ColumnDefinitions="Auto,*">
                <TextBlock Text="vol" Classes="caption" VerticalAlignment="Center"
                           Margin="0,0,8,0" />
                <NumericUpDown Grid.Column="1" Value="{Binding Volume}"
                               Minimum="0" Maximum="100" FormatString="0"
                               FontSize="12" Padding="8,4"
                               ToolTip.Tip="applies from the next track" />
            </Grid>

            <Grid ColumnDefinitions="*,Auto">
                <TextBlock Text="{Binding FolderLabel}" Classes="caption"
                           VerticalAlignment="Center" TextTrimming="CharacterEllipsis" />
                <Button Grid.Column="1" Classes="seg" Content="folder…"
                        Click="OnChooseMusicFolder" />
            </Grid>

            <TextBlock Text="spotify connect — coming soon" Classes="caption" Opacity="0.6" />
            <TextBlock Text="player not supported on this OS yet" Classes="caption overest"
                       IsVisible="{Binding !IsSupported}" />
        </StackPanel>
    </Border>

    <!-- The bubble itself — hidden entirely when music is switched off -->
    <Button Classes="musicbubble"
            Classes.playing="{Binding Music.IsPlaying}"
            IsVisible="{Binding Music.IsEnabled}"
            HorizontalAlignment="Right" VerticalAlignment="Bottom"
            Margin="0,0,20,20"
            Command="{Binding Music.TogglePanelCommand}"
            ToolTip.Tip="音楽 · music">
        <StackPanel Orientation="Horizontal" Spacing="2" VerticalAlignment="Center"
                    HorizontalAlignment="Center" Height="18">
            <Rectangle Classes="eq eq1" />
            <Rectangle Classes="eq eq2" />
            <Rectangle Classes="eq eq3" />
            <Rectangle Classes="eq eq4" />
        </StackPanel>
    </Button>

    <!-- Command palette (Cmd/Ctrl+K) -->
    <Border Classes="modal-backdrop"
            IsVisible="{Binding IsCommandPaletteOpen}"
            Classes.open="{Binding IsCommandPaletteOpen}"
            Background="#A0000000">
        <Border Classes="card modal-card"
                Width="460" Padding="14"
                HorizontalAlignment="Center" VerticalAlignment="Top"
                Margin="0,90,0,0"
                DataContext="{Binding CommandPalette}"
                RenderTransformOrigin="0.5,0.5">
            <Border.RenderTransform>
                <ScaleTransform ScaleX="1" ScaleY="1" />
            </Border.RenderTransform>
            <StackPanel Spacing="8">
                <TextBox x:Name="PaletteBox" Text="{Binding Query}"
                         Watermark="jump to… (pages, actions, subjects)"
                         KeyDown="OnPaletteKeyDown" />
                <ListBox ItemsSource="{Binding Results}"
                         SelectedIndex="{Binding SelectedIndex}"
                         Classes="tasks" MaxHeight="320">
                    <ListBox.ItemTemplate>
                        <DataTemplate x:DataType="vm:PaletteItemViewModel">
                            <Grid ColumnDefinitions="*,Auto">
                                <TextBlock Text="{Binding Title}" VerticalAlignment="Center" />
                                <TextBlock Grid.Column="1" Text="{Binding Kind}" Classes="caption"
                                           VerticalAlignment="Center" />
                            </Grid>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
                <TextBlock Text="↑↓ move · enter run · esc close" Classes="caption" />
            </StackPanel>
        </Border>
    </Border>

    <!-- Welcome modal: the launch greeting -->
    <Border Classes="modal-backdrop"
            IsVisible="{Binding IsWelcomeOpen}"
            Classes.open="{Binding IsWelcomeOpen}"
            Background="#A0000000">
        <Border Classes="card modal-card"
                Width="430" Padding="26"
                HorizontalAlignment="Center" VerticalAlignment="Center"
                RenderTransformOrigin="0.5,0.5">
            <Border.RenderTransform>
                <ScaleTransform ScaleX="1" ScaleY="1" />
            </Border.RenderTransform>
            <StackPanel Spacing="14">
                <StackPanel Spacing="2">
                    <TextBlock Text="灯火 · tomoshibi" Classes="jp" />
                    <TextBlock Text="{Binding Today.Greeting}" Classes="h1" />
                    <TextBlock Text="{Binding WelcomeDateLabel}" Classes="caption" />
                </StackPanel>

                <StackPanel Spacing="4">
                    <TextBlock Text="{Binding Today.NextClassLabel}" FontSize="13"
                               Foreground="{DynamicResource BlueBrush}"
                               IsVisible="{Binding Today.HasNextClass}" />
                    <TextBlock Text="{Binding Today.DeadlinesLabel}" FontSize="13"
                               Foreground="{DynamicResource AmberBrush}"
                               IsVisible="{Binding Today.HasUpcomingDeadlines}" />
                    <TextBlock FontSize="13" Classes="caption">
                        <Run Text="{Binding Todo.OpenCount, Mode=OneWay}" />
                        <Run Text=" backlog · " />
                        <Run Text="{Binding Todo.DoingCount, Mode=OneWay}" />
                        <Run Text=" doing · " />
                        <Run Text="{Binding Today.StreakDays, Mode=OneWay}" />
                        <Run Text=" day streak" />
                    </TextBlock>
                </StackPanel>

                <StackPanel Spacing="6">
                    <TextBlock Text="今日の狙い · what do you want to do today?" Classes="jp" />
                    <TextBox Text="{Binding Today.DailyIntention}"
                             Watermark="the one thing…" />
                </StackPanel>

                <Grid ColumnDefinitions="*,*" Margin="0,4,0,0">
                    <Button Grid.Column="0" Content="just looking"
                            HorizontalAlignment="Stretch"
                            Command="{Binding CloseWelcomeCommand}" />
                    <Button Grid.Column="1" Content="start focusing" Classes="accent"
                            HorizontalAlignment="Stretch" Margin="8,0,0,0"
                            Command="{Binding WelcomeStartFocusCommand}" />
                </Grid>

                <Button Classes="seg" Content="✦ new here? take the quick tour"
                        HorizontalAlignment="Center"
                        Command="{Binding OpenTourCommand}" />

                <CheckBox IsChecked="{Binding ShowWelcomeOnLaunch}"
                          Content="greet me on launch" FontSize="12" />
            </StackPanel>
        </Border>
    </Border>

    <!-- What's new: shown once after an update; the app behind it blurs. -->
    <Border Classes="modal-backdrop"
            IsVisible="{Binding IsWhatsNewOpen}"
            Classes.open="{Binding IsWhatsNewOpen}"
            Background="#A0000000">
        <Border Classes="card modal-card" Width="540" Padding="30"
                HorizontalAlignment="Center" VerticalAlignment="Center">
            <StackPanel Spacing="14">
                <StackPanel Spacing="3">
                    <TextBlock Text="灯火 · tomoshibi" Classes="jp" />
                    <Grid ColumnDefinitions="*,Auto">
                        <TextBlock Text="{Binding WhatsNewTitle}" Classes="h1"
                                   VerticalAlignment="Bottom" />
                        <TextBlock Grid.Column="1" Text="{Binding AppVersionTag}"
                                   Classes="caption" VerticalAlignment="Bottom" />
                    </Grid>
                </StackPanel>
                <Border Height="1" Background="{DynamicResource BorderBrush}" />
                <TextBlock Text="{Binding WhatsNewBody}" TextWrapping="Wrap"
                           FontSize="13" LineHeight="24"
                           Foreground="{DynamicResource MutedTextBrush}" />
                <Button Classes="accent" Content="got it" HorizontalAlignment="Right"
                        Command="{Binding CloseWhatsNewCommand}" />
            </StackPanel>
        </Border>
    </Border>

    <!-- The tour: a four-page primer over the whole shell. Static content;
         the pages teach the things nobody discovers alone (tasks-as-code,
         the palette, the keyboard). Reachable from welcome, settings and
         the palette itself. -->
    <Border Classes="modal-backdrop"
            IsVisible="{Binding IsTourOpen}"
            Classes.open="{Binding IsTourOpen}"
            Background="#A0000000">
        <Border Classes="card modal-card" Width="560" Padding="30"
                HorizontalAlignment="Center" VerticalAlignment="Center">
            <StackPanel Spacing="16">

                <!-- Page 1 · the rooms -->
                <StackPanel Spacing="12" IsVisible="{Binding IsTourPage0}" MinHeight="240">
                    <TextBlock Text="灯火 · a quick tour" Classes="jp" />
                    <TextBlock Text="案内 · the rooms" Classes="h1 cjk" />
                    <StackPanel Spacing="8" Margin="0,6,0,0">
                        <TextBlock TextWrapping="Wrap" FontSize="13" LineHeight="22"
                                   Foreground="{DynamicResource MutedTextBrush}"
                                   Text="›  dashboard — the morning glance: intention, momentum, what's due&#x0a;›  today — the pomodoro timer and the day's plan, side by side&#x0a;›  timetable · todo · subjects — classes, coursework tickets and grades&#x0a;›  stats · review — the record: streaks, the journal, flashcards" />
                        <TextBlock Text="everything stays on your machine, in one json file"
                                   Classes="caption" />
                    </StackPanel>
                </StackPanel>

                <!-- Page 2 · tasks as code -->
                <StackPanel Spacing="12" IsVisible="{Binding IsTourPage1}" MinHeight="240">
                    <TextBlock Text="灯火 · a quick tour" Classes="jp" />
                    <TextBlock Text="コード · tasks as code" Classes="h1 cjk" />
                    <TextBlock TextWrapping="Wrap" FontSize="13" LineHeight="22"
                               Foreground="{DynamicResource MutedTextBrush}"
                               Text="today's plan is a tiny program. click a task and it drives the timer." />
                    <Border Background="{DynamicResource InkBrush}" CornerRadius="6" Padding="14,10">
                        <TextBlock FontFamily="{DynamicResource MonoFont}" FontSize="13" LineHeight="22"
                                   Text="// linear algebra — problem set 5&#x0a;study: 25&#x0a;course: MATH201" />
                    </Border>
                    <TextBlock TextWrapping="Wrap" Classes="caption"
                               Text="// titles a task · study: sets the minutes · done ticks it off — or skip the code and use the form, same thing" />
                </StackPanel>

                <!-- Page 3 · the keyboard -->
                <StackPanel Spacing="12" IsVisible="{Binding IsTourPage2}" MinHeight="240">
                    <TextBlock Text="灯火 · a quick tour" Classes="jp" />
                    <TextBlock Text="鍵盤 · the keyboard" Classes="h1 cjk" />
                    <TextBlock TextWrapping="Wrap" FontSize="13" LineHeight="24"
                               Foreground="{DynamicResource MutedTextBrush}">
                        <Run Text="›  " /><Run Text="{Binding PaletteChordLabel, Mode=OneWay}" Foreground="{DynamicResource MatchaBrush}" /><Run Text=" — the command palette: jump anywhere, run anything" />
                        <LineBreak />
                        <Run Text="›  space — start / pause the timer  ·  z — zen mode" />
                        <LineBreak />
                        <Run Text="›  1 · 2 · 3 — grade cards during a review session" />
                        <LineBreak />
                        <Run Text="›  " /><Run Text="{Binding GlobalChordLabel, Mode=OneWay}" Foreground="{DynamicResource MatchaBrush}" /><Run Text=" — start / pause from any app, even from the tray" />
                    </TextBlock>
                </StackPanel>

                <!-- Page 4 · embers & the streak -->
                <StackPanel Spacing="12" IsVisible="{Binding IsTourPage3}" MinHeight="240">
                    <TextBlock Text="灯火 · a quick tour" Classes="jp" />
                    <TextBlock Text="火種 · embers &amp; the streak" Classes="h1 cjk" />
                    <TextBlock TextWrapping="Wrap" FontSize="13" LineHeight="22"
                               Foreground="{DynamicResource MutedTextBrush}"
                               Text="›  focusing earns 火種 embers — spend them on colour themes in the shop&#x0a;›  set an intention each morning, mark it kept, reflect in the evening&#x0a;›  the streak counts the days you showed up — the calendar keeps score&#x0a;›  the getting-started checklist on the dashboard pays a few embers to start" />
                    <TextBlock Text="that's the whole idea. keep a small light on."
                               Classes="caption" />
                </StackPanel>

                <!-- Footer: back · dots · next/done -->
                <Grid ColumnDefinitions="80,*,80" Margin="0,4,0,0">
                    <Button Grid.Column="0" Classes="seg" Content="← back"
                            HorizontalAlignment="Left"
                            IsVisible="{Binding !IsTourPage0}"
                            Command="{Binding PrevTourPageCommand}" />
                    <TextBlock Grid.Column="1" Text="{Binding TourDots}"
                               HorizontalAlignment="Center" VerticalAlignment="Center"
                               Classes="caption" />
                    <Button Grid.Column="2" Classes="accent" Content="next →"
                            HorizontalAlignment="Right"
                            IsVisible="{Binding !IsTourLastPage}"
                            Command="{Binding NextTourPageCommand}" />
                    <Button Grid.Column="2" Classes="accent" Content="start"
                            HorizontalAlignment="Right"
                            IsVisible="{Binding IsTourLastPage}"
                            Command="{Binding NextTourPageCommand}" />
                </Grid>
            </StackPanel>
        </Border>
    </Border>

    <!-- Zen layout: timer only, everything else fades -->
    <Grid IsVisible="{Binding IsZenMode}" RowDefinitions="Auto,*,Auto" Margin="48">

        <Button Grid.Row="0" Classes="icon" Content="✕" FontSize="18"
                HorizontalAlignment="Right" VerticalAlignment="Top"
                Command="{Binding ExitZenCommand}"
                ToolTip.Tip="esc · exit" />

        <StackPanel Grid.Row="1" VerticalAlignment="Center"
                    HorizontalAlignment="Center" Spacing="18">
            <TextBlock Text="{Binding Today.Pomodoro.PhaseLabel}" Classes="jp"
                       HorizontalAlignment="Center" />
            <TextBlock Text="{Binding Today.Pomodoro.TimeDisplay}" FontSize="180" FontWeight="Light"
                       Foreground="{Binding Today.Pomodoro.Phase, Converter={StaticResource PhaseToBrush}}"
                       Classes="timer" Classes.paused="{Binding Today.Pomodoro.IsPaused}"
                       HorizontalAlignment="Center">
                <TextBlock.Transitions>
                    <Transitions>
                        <BrushTransition Property="Foreground" Duration="0:0:0.45" />
                        <DoubleTransition Property="Opacity" Duration="0:0:0.3" />
                    </Transitions>
                </TextBlock.Transitions>
            </TextBlock>
            <ProgressBar Value="{Binding Today.Pomodoro.Progress}" Minimum="0" Maximum="1"
                         Width="560" Height="5" MinHeight="0"
                         Foreground="{Binding Today.Pomodoro.Phase, Converter={StaticResource PhaseToBrush}}"
                         Background="{DynamicResource BorderBrush}">
                <ProgressBar.Transitions>
                    <Transitions>
                        <DoubleTransition Property="Value" Duration="0:0:1" />
                        <BrushTransition Property="Foreground" Duration="0:0:0.45" />
                    </Transitions>
                </ProgressBar.Transitions>
            </ProgressBar>
            <TextBlock Text="{Binding Today.Pomodoro.RoundLabel}" Classes="caption"
                       HorizontalAlignment="Center" />
            <TextBlock Text="{Binding Today.ActiveTaskLabel}" Classes="caption"
                       Foreground="{DynamicResource MatchaBrush}"
                       HorizontalAlignment="Center"
                       IsVisible="{Binding Today.HasActiveTask}" />

            <!-- The day's intention follows you into zen -->
            <TextBlock Text="{Binding Today.DailyIntention}" Classes="caption"
                       HorizontalAlignment="Center" Margin="0,24,0,0"
                       MaxWidth="560" TextWrapping="Wrap" TextAlignment="Center"
                       IsVisible="{Binding Today.DailyIntention, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />
        </StackPanel>

        <StackPanel Grid.Row="2" HorizontalAlignment="Center" Spacing="16" Margin="0,0,0,12">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Spacing="12">
                <Button Content="{Binding Today.Pomodoro.StartPauseLabel}" Classes="accent"
                        Command="{Binding Today.Pomodoro.ToggleRunCommand}" />
                <Button Content="reset" Command="{Binding Today.Pomodoro.ResetCommand}" />
                <Button Content="skip" Command="{Binding Today.Pomodoro.SkipCommand}" />
            </StackPanel>

            <!-- After-midnight nudge sits at the very bottom in zen, not under
                 the timer. Hover to reveal the dismiss ✕. -->
            <Border Classes="sleep-nudge" HorizontalAlignment="Center"
                    IsVisible="{Binding Today.ShowSleepNudge}">
                <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                    <TextBlock Text="☾" FontSize="13"
                               Foreground="{DynamicResource BlueBrush}"
                               VerticalAlignment="Center" />
                    <TextBlock Text="おやすみ · it's late — rest soon"
                               Classes="cjk" FontSize="13"
                               Foreground="{DynamicResource BlueBrush}"
                               VerticalAlignment="Center" />
                    <Button Classes="nudge-dismiss" Content="✕"
                            Command="{Binding Today.DismissSleepNudgeCommand}"
                            ToolTip.Tip="dismiss for tonight" />
                </StackPanel>
            </Border>
        </StackPanel>
    </Grid>

    <!-- Launch splash: covers everything, the lamp fades up, then the
         overlay fades out to reveal the app. Last child = topmost. -->
    <Border Classes="splash" Classes.booting="{Binding IsBooting}"
            Background="{DynamicResource InkBrush}">
        <StackPanel Classes="splashinner" Spacing="14"
                    VerticalAlignment="Center" HorizontalAlignment="Center"
                    RenderTransformOrigin="0.5,0.5">
            <StackPanel.RenderTransform>
                <ScaleTransform ScaleX="1" ScaleY="1" />
            </StackPanel.RenderTransform>
            <TextBlock Text="灯" FontSize="96" HorizontalAlignment="Center"
                       Foreground="{DynamicResource MatchaBrush}" />
            <TextBlock Text="灯火 · tomoshibi" Classes="jp" HorizontalAlignment="Center" />
        </StackPanel>
    </Border>

    </Grid>
</Window>
