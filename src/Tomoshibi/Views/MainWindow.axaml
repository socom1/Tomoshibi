<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:Tomoshibi.ViewModels"
        xmlns:conv="using:Tomoshibi.Converters"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        x:Class="Tomoshibi.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Title="tomoshibi"
        Width="980" Height="680"
        MinWidth="820" MinHeight="560"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource InkBrush}">

    <Window.Resources>
        <conv:PhaseToBrushConverter x:Key="PhaseToBrush" />
    </Window.Resources>

    <Window.KeyBindings>
        <KeyBinding Gesture="Escape" Command="{Binding ExitZenCommand}" />
    </Window.KeyBindings>

    <Design.DataContext>
        <vm:MainWindowViewModel />
    </Design.DataContext>

    <Grid>

    <!-- Normal layout: nav rail | divider | main content. Column widths are
         set in code-behind; opening the nav slides it in from zero width. -->
    <Grid x:Name="NormalLayoutGrid" IsVisible="{Binding !IsZenMode}">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="0" />
            <ColumnDefinition Width="0" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- ============ Nav rail ============ -->
        <Border Grid.Column="0" IsVisible="{Binding IsNavOpen}"
                Background="{DynamicResource InkBrush}">
            <StackPanel Margin="0,28,0,28" Spacing="2">
                <TextBlock Text="灯火 · tomoshibi" Classes="jp"
                           Margin="22,0,22,24" />

                <Button Classes="nav" Classes.active="{Binding IsTodayActive}"
                        Command="{Binding NavigateToTodayCommand}">
                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <TextBlock Text="今日" />
                        <TextBlock Text="today" Opacity="0.55" />
                    </StackPanel>
                </Button>

                <Button Classes="nav" Classes.active="{Binding IsTimetableActive}"
                        Command="{Binding NavigateToTimetableCommand}">
                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <TextBlock Text="時間割" />
                        <TextBlock Text="timetable" Opacity="0.55" />
                    </StackPanel>
                </Button>
            </StackPanel>
        </Border>

        <Border Grid.Column="1"
                Background="{DynamicResource BorderBrush}"
                IsVisible="{Binding IsNavOpen}" />

        <!-- ============ Main area: header + active destination ============ -->
        <Grid Grid.Column="2" RowDefinitions="Auto,*">

            <!-- Header -->
            <Grid Grid.Row="0" Margin="28,28,28,0" ColumnDefinitions="Auto,*,Auto,Auto">

                <!-- Nav toggle -->
                <Button Grid.Column="0" Classes="icon" Content="☰" FontSize="18"
                        VerticalAlignment="Top" Margin="0,6,16,0"
                        Command="{Binding ToggleNavCommand}"
                        ToolTip.Tip="menu · メニュー" />

                <StackPanel Grid.Column="1" Spacing="2">
                    <TextBlock Text="灯火 · tomoshibi" Classes="jp"
                               IsVisible="{Binding !IsNavOpen}" />
                    <TextBlock Text="{Binding Greeting}" Classes="h1" />
                </StackPanel>

                <!-- Zen -->
                <Button Grid.Column="2" Classes="icon" Content="⛶" FontSize="20"
                        VerticalAlignment="Top" Margin="0,0,4,0"
                        Command="{Binding ToggleZenCommand}"
                        ToolTip.Tip="集中 · zen" />

                <!-- Settings -->
                <Button Grid.Column="3" Classes="icon" Content="⚙" FontSize="20"
                        VerticalAlignment="Top" ToolTip.Tip="設定 · settings">
                    <Button.Flyout>
                        <Flyout Placement="BottomEdgeAlignedRight">
                            <StackPanel Width="250" Spacing="12" Margin="8">
                                <TextBlock Text="設定 · settings" Classes="jp" />

                                <Grid ColumnDefinitions="*,90">
                                    <TextBlock Text="focus (min)" VerticalAlignment="Center" />
                                    <NumericUpDown Grid.Column="1" Value="{Binding Settings.FocusMinutes}"
                                                   Minimum="1" Maximum="120" Increment="1" FormatString="0" />
                                </Grid>
                                <Grid ColumnDefinitions="*,90">
                                    <TextBlock Text="short break" VerticalAlignment="Center" />
                                    <NumericUpDown Grid.Column="1" Value="{Binding Settings.ShortBreakMinutes}"
                                                   Minimum="1" Maximum="60" Increment="1" FormatString="0" />
                                </Grid>
                                <Grid ColumnDefinitions="*,90">
                                    <TextBlock Text="long break" VerticalAlignment="Center" />
                                    <NumericUpDown Grid.Column="1" Value="{Binding Settings.LongBreakMinutes}"
                                                   Minimum="1" Maximum="60" Increment="1" FormatString="0" />
                                </Grid>
                                <Grid ColumnDefinitions="*,90">
                                    <TextBlock Text="rounds / long" VerticalAlignment="Center" />
                                    <NumericUpDown Grid.Column="1" Value="{Binding Settings.RoundsBeforeLongBreak}"
                                                   Minimum="1" Maximum="12" Increment="1" FormatString="0" />
                                </Grid>

                                <TextBlock Text="applies live · running phase finishes first" Classes="caption" />
                            </StackPanel>
                        </Flyout>
                    </Button.Flyout>
                </Button>
            </Grid>

            <!-- Active destination's view, resolved via ViewLocator -->
            <ContentControl Grid.Row="1" Content="{Binding ActiveContent}" />
        </Grid>
    </Grid>

    <!-- Zen layout: timer only, everything else fades -->
    <Grid IsVisible="{Binding IsZenMode}" RowDefinitions="Auto,*,Auto" Margin="48">

        <Button Grid.Row="0" Classes="icon" Content="✕" FontSize="18"
                HorizontalAlignment="Right" VerticalAlignment="Top"
                Command="{Binding ExitZenCommand}"
                ToolTip.Tip="esc · exit" />

        <StackPanel Grid.Row="1" VerticalAlignment="Center"
                    HorizontalAlignment="Center" Spacing="18">
            <TextBlock Text="{Binding Today.Pomodoro.PhaseLabel}" Classes="jp"
                       HorizontalAlignment="Center" />
            <TextBlock Text="{Binding Today.Pomodoro.TimeDisplay}" FontSize="180" FontWeight="Light"
                       Foreground="{Binding Today.Pomodoro.Phase, Converter={StaticResource PhaseToBrush}}"
                       HorizontalAlignment="Center" />
            <ProgressBar Value="{Binding Today.Pomodoro.Progress}" Minimum="0" Maximum="1"
                         Width="560" Height="5" MinHeight="0"
                         Foreground="{Binding Today.Pomodoro.Phase, Converter={StaticResource PhaseToBrush}}"
                         Background="{DynamicResource BorderBrush}" />
            <TextBlock Text="{Binding Today.Pomodoro.RoundLabel}" Classes="caption"
                       HorizontalAlignment="Center" />
        </StackPanel>

        <StackPanel Grid.Row="2" Orientation="Horizontal"
                    HorizontalAlignment="Center" Spacing="12" Margin="0,0,0,12">
            <Button Content="{Binding Today.Pomodoro.StartPauseLabel}" Classes="accent"
                    Command="{Binding Today.Pomodoro.ToggleRunCommand}" />
            <Button Content="reset" Command="{Binding Today.Pomodoro.ResetCommand}" />
            <Button Content="skip" Command="{Binding Today.Pomodoro.SkipCommand}" />
        </StackPanel>
    </Grid>

    </Grid>
</Window>
