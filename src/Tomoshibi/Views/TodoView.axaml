<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Tomoshibi.ViewModels"
             xmlns:conv="using:Tomoshibi.Converters"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             x:Class="Tomoshibi.Views.TodoView"
             x:DataType="vm:TodoViewModel">

    <Grid>

    <Grid RowDefinitions="Auto,Auto,*" Margin="28,4,28,28" MaxWidth="860">

        <!-- Page header -->
        <Grid Grid.Row="0" ColumnDefinitions="*,Auto" Margin="0,0,0,16">
            <StackPanel Spacing="3">
                <TextBlock Classes="path" Text="~/tomoshibi/todo" />
                <StackPanel Orientation="Horizontal" Spacing="10">
                    <TextBlock Text="❯" Classes="prompt" />
                    <TextBlock Text="やること · backlog" Classes="h1 cjk" VerticalAlignment="Center" />
                </StackPanel>
                <TextBlock Classes="caption">
                    <Run Text="{Binding OpenCount, Mode=OneWay}" />
                    <Run Text=" backlog · " />
                    <Run Text="{Binding DoingCount, Mode=OneWay}" />
                    <Run Text=" doing · " />
                    <Run Text="{Binding DoneCount, Mode=OneWay}" />
                    <Run Text=" shipped" />
                </TextBlock>
            </StackPanel>

            <Button Grid.Column="1" Classes="accent" Content="+ new"
                    VerticalAlignment="Top"
                    Command="{Binding OpenAddCommand}" />
        </Grid>

        <!-- Filter bar -->
        <Grid Grid.Row="1" ColumnDefinitions="Auto,Auto,Auto,16,*" Margin="0,0,0,12">
            <Button Grid.Column="0" Classes="seg" Content="open"
                    Classes.active="{Binding IsOpenFilter}"
                    Command="{Binding ShowOpenCommand}" />
            <Button Grid.Column="1" Classes="seg" Content="done"
                    Classes.active="{Binding IsDoneFilter}"
                    Command="{Binding ShowDoneCommand}" />
            <Button Grid.Column="2" Classes="seg" Content="all"
                    Classes.active="{Binding IsAllFilter}"
                    Command="{Binding ShowAllCommand}" />

            <TextBox Grid.Column="4" Text="{Binding SearchText}"
                     Watermark="search title, notes, course…" />
        </Grid>

        <!-- Tickets -->
        <Border Grid.Row="2" Classes="card">
            <Grid>
                <ScrollViewer VerticalScrollBarVisibility="Auto"
                              IsVisible="{Binding HasVisibleItems}">
                    <ItemsControl ItemsSource="{Binding Items}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="vm:TodoItemViewModel">
                                <StackPanel Margin="0,2,0,2">

                                    <!-- Row line -->
                                    <Border Classes="trow">
                                    <Grid ColumnDefinitions="Auto,Auto,Auto,*,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto">
                                        <Button Grid.Column="0" Classes="icon" Content="{Binding ChevronGlyph}"
                                                FontSize="11" Padding="4,2"
                                                Command="{Binding ToggleExpandedCommand}"
                                                ToolTip.Tip="show / hide details" />
                                        <Button Grid.Column="1" Classes="icon status"
                                                Classes.doing="{Binding IsDoing}"
                                                Classes.donestat="{Binding IsDone}"
                                                Content="{Binding StatusGlyph}" FontSize="14"
                                                Command="{Binding CycleStatusCommand}"
                                                ToolTip.Tip="{Binding StatusTip}" />
                                        <TextBlock Grid.Column="2" Text="{Binding NumberLabel}"
                                                   Classes="caption" VerticalAlignment="Center"
                                                   MinWidth="32" Margin="2,0,8,0" />
                                        <TextBlock Grid.Column="3" Text="{Binding Title}"
                                                   Classes.done="{Binding IsDone}"
                                                   VerticalAlignment="Center" TextWrapping="Wrap" />
                                        <TextBlock Grid.Column="4" Text="{Binding DueLabel}"
                                                   Classes="caption" Margin="8,0,0,0"
                                                   Classes.overdue="{Binding IsOverdue}"
                                                   VerticalAlignment="Center"
                                                   IsVisible="{Binding HasDue}" />
                                        <Border Grid.Column="5" Classes="tag prio" Margin="8,0,0,0"
                                                Classes.high="{Binding IsHighPriority}"
                                                IsVisible="{Binding HasPriorityChip}">
                                            <TextBlock Text="{Binding PriorityLabel}" />
                                        </Border>
                                        <TextBlock Grid.Column="6" Text="{Binding SubtaskProgress}"
                                                   Classes="caption" Margin="8,0,0,0"
                                                   VerticalAlignment="Center"
                                                   IsVisible="{Binding HasSubtasks}" />
                                        <TextBlock Grid.Column="7" Text="{Binding EffortLabel}"
                                                   Classes="caption" Margin="8,0,0,0"
                                                   Classes.overest="{Binding IsOverEstimate}"
                                                   VerticalAlignment="Center"
                                                   ToolTip.Tip="focus sessions spent / estimated"
                                                   IsVisible="{Binding HasEffort}" />
                                        <Border Grid.Column="8" Classes="tag" Margin="8,0,0,0"
                                                IsVisible="{Binding HasCourse}">
                                            <TextBlock Text="{Binding Course}" Foreground="{Binding Course, Converter={StaticResource CourseColor}}" />
                                        </Border>
                                        <Button Grid.Column="9" Content="→" Classes="icon" Margin="4,0,0,0"
                                                ToolTip.Tip="send to today"
                                                Command="{Binding $parent[ItemsControl].((vm:TodoViewModel)DataContext).SendToTodayCommand}"
                                                CommandParameter="{Binding}" />
                                        <Button Grid.Column="10" Content="✎" Classes="icon"
                                                ToolTip.Tip="edit"
                                                Click="OnEditClick" />
                                        <Button Grid.Column="11" Content="✕" Classes="icon"
                                                Command="{Binding $parent[ItemsControl].((vm:TodoViewModel)DataContext).RemoveCommand}"
                                                CommandParameter="{Binding}" />
                                    </Grid>
                                    </Border>

                                    <!-- Expanded details -->
                                    <Border IsVisible="{Binding IsExpanded}"
                                            Margin="26,4,0,6" Padding="12,10"
                                            Background="{DynamicResource InkBrush}"
                                            CornerRadius="6">
                                        <StackPanel Spacing="10">
                                            <TextBlock Text="{Binding Description}"
                                                       TextWrapping="Wrap" FontSize="13"
                                                       IsVisible="{Binding HasDescription}" />

                                            <!-- Subtasks -->
                                            <ItemsControl ItemsSource="{Binding Subtasks}"
                                                          IsVisible="{Binding HasSubtasks}">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate x:DataType="vm:SubtaskViewModel">
                                                        <Grid ColumnDefinitions="Auto,*,Auto" Margin="0,2,0,0">
                                                            <CheckBox Grid.Column="0" IsChecked="{Binding IsDone}"
                                                                      MinHeight="0" Padding="0"
                                                                      VerticalAlignment="Center" Margin="0,0,8,0" />
                                                            <TextBlock Grid.Column="1" Text="{Binding Title}"
                                                                       Classes.done="{Binding IsDone}"
                                                                       FontSize="13"
                                                                       VerticalAlignment="Center" TextWrapping="Wrap" />
                                                            <Button Grid.Column="2" Content="✕" Classes="icon"
                                                                    FontSize="11" Padding="4,2"
                                                                    Command="{Binding $parent[ItemsControl].((vm:TodoItemViewModel)DataContext).RemoveSubtaskCommand}"
                                                                    CommandParameter="{Binding}" />
                                                        </Grid>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>

                                            <!-- Add subtask -->
                                            <Grid ColumnDefinitions="*,Auto">
                                                <TextBox Text="{Binding NewSubtaskTitle}"
                                                         Watermark="add a step…"
                                                         FontSize="13" Padding="10,6">
                                                    <TextBox.KeyBindings>
                                                        <KeyBinding Gesture="Enter" Command="{Binding AddSubtaskCommand}" />
                                                    </TextBox.KeyBindings>
                                                </TextBox>
                                                <Button Grid.Column="1" Content="+" Classes="icon" Margin="4,0,0,0"
                                                        Command="{Binding AddSubtaskCommand}" />
                                            </Grid>

                                            <TextBlock Text="{Binding MetaLabel}" Classes="caption" />
                                        </StackPanel>
                                    </Border>
                                </StackPanel>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>

                <TextBlock Text="何もない · nothing here"
                           Classes="jp" HorizontalAlignment="Center" VerticalAlignment="Center"
                           IsVisible="{Binding !HasVisibleItems}" />
            </Grid>
        </Border>
    </Grid>

    </Grid>
</UserControl>
