<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Tomoshibi.ViewModels"
             xmlns:m="using:Tomoshibi.Models"
             xmlns:conv="using:Tomoshibi.Converters"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             x:Class="Tomoshibi.Views.TodayView"
             x:DataType="vm:TodayViewModel">

    <UserControl.Resources>
        <conv:PhaseToBrushConverter x:Key="PhaseToBrush" />
    </UserControl.Resources>

    <Grid RowDefinitions="Auto,*" Margin="28,4,28,28">

        <!-- Page header -->
        <Grid Grid.Row="0" ColumnDefinitions="*,Auto,Auto" Margin="0,0,0,20">
            <StackPanel Grid.Column="0" Spacing="2">
                <TextBlock Text="ポモドーロ · Pomodoro" Classes="jp" />
            </StackPanel>

            <Button Grid.Column="1" Classes="icon" Content="⛶" FontSize="20"
                    VerticalAlignment="Top" Margin="0,0,4,0"
                    Command="{Binding ToggleZenCommand}"
                    ToolTip.Tip="集中 · zen" />

            <Button Grid.Column="2" Classes="icon" Content="⚙" FontSize="20"
                    VerticalAlignment="Top" ToolTip.Tip="設定 · settings">
                <Button.Flyout>
                    <Flyout Placement="BottomEdgeAlignedRight">
                        <StackPanel Width="250" Spacing="12" Margin="8">
                            <TextBlock Text="設定 · settings" Classes="jp" />

                            <Grid ColumnDefinitions="*,90">
                                <TextBlock Text="focus (min)" VerticalAlignment="Center" />
                                <NumericUpDown Grid.Column="1" Value="{Binding Settings.FocusMinutes}"
                                               Minimum="1" Maximum="120" Increment="1" FormatString="0" />
                            </Grid>
                            <Grid ColumnDefinitions="*,90">
                                <TextBlock Text="short break" VerticalAlignment="Center" />
                                <NumericUpDown Grid.Column="1" Value="{Binding Settings.ShortBreakMinutes}"
                                               Minimum="1" Maximum="60" Increment="1" FormatString="0" />
                            </Grid>
                            <Grid ColumnDefinitions="*,90">
                                <TextBlock Text="long break" VerticalAlignment="Center" />
                                <NumericUpDown Grid.Column="1" Value="{Binding Settings.LongBreakMinutes}"
                                               Minimum="1" Maximum="60" Increment="1" FormatString="0" />
                            </Grid>
                            <Grid ColumnDefinitions="*,90">
                                <TextBlock Text="rounds / long" VerticalAlignment="Center" />
                                <NumericUpDown Grid.Column="1" Value="{Binding Settings.RoundsBeforeLongBreak}"
                                               Minimum="1" Maximum="12" Increment="1" FormatString="0" />
                            </Grid>

                            <CheckBox IsChecked="{Binding Settings.AutoContinue}"
                                      Content="auto-continue phases" />
                            <CheckBox IsChecked="{Binding Settings.ChimeEnabled}"
                                      Content="chime on phase change" />
                            <CheckBox IsChecked="{Binding Settings.NotificationsEnabled}"
                                      Content="notify on phase change" />

                            <TextBlock Text="applies live · running phase finishes first" Classes="caption" />
                        </StackPanel>
                    </Flyout>
                </Button.Flyout>
            </Button>
        </Grid>

        <!-- Body: the timer on the left, tasks on the right. The overview
             (intention, stats, what's next) lives on the dashboard. -->
        <Grid Grid.Row="1" ColumnDefinitions="*,320">

            <!-- Focus / pomodoro — a terminal "focus pane": phase-coloured
                 border, a title bar with the live spinner, the clock + gauge,
                 a session log, and a keybind footer. The "minimal" toggle
                 drops the log + footer for a calmer view. -->
            <Border Grid.Column="0" Classes="card" Margin="0,0,20,0"
                    BorderThickness="1"
                    BorderBrush="{Binding Pomodoro.Phase, Converter={StaticResource PhaseToBrush}}">
                <Border.Transitions>
                    <Transitions>
                        <BrushTransition Property="BorderBrush" Duration="0:0:0.45" />
                    </Transitions>
                </Border.Transitions>
                <Grid RowDefinitions="Auto,*,Auto,Auto">

                    <!-- Panel title bar -->
                    <Grid Grid.Row="0" ColumnDefinitions="*,Auto">
                        <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                            <TextBlock Text="{Binding Pomodoro.Spinner}" FontSize="13"
                                       VerticalAlignment="Center"
                                       Foreground="{Binding Pomodoro.Phase, Converter={StaticResource PhaseToBrush}}" />
                            <TextBlock Text="{Binding Pomodoro.PhaseLabel}" Classes="jp"
                                       VerticalAlignment="Center" />
                        </StackPanel>
                        <ToggleButton Grid.Column="1" Classes="seg" Content="minimal"
                                      IsChecked="{Binding SimpleTimer}"
                                      Classes.active="{Binding SimpleTimer}"
                                      ToolTip.Tip="simple / full timer" />
                    </Grid>

                    <!-- The clock group scales to fill the card. The fixed inner
                         width gives the Viewbox a definite ratio to scale by. -->
                    <Viewbox Grid.Row="1" Stretch="Uniform" StretchDirection="Both"
                             MaxWidth="540" MaxHeight="320" Margin="10"
                             HorizontalAlignment="Center" VerticalAlignment="Center">
                        <StackPanel Width="380" HorizontalAlignment="Center" Spacing="14">

                            <TextBlock Text="{Binding Pomodoro.TimeDisplay}" FontSize="86" FontWeight="Light"
                                       Foreground="{Binding Pomodoro.Phase, Converter={StaticResource PhaseToBrush}}"
                                       Classes="timer" Classes.paused="{Binding Pomodoro.IsPaused}"
                                       HorizontalAlignment="Center">
                                <TextBlock.Transitions>
                                    <Transitions>
                                        <BrushTransition Property="Foreground" Duration="0:0:0.45" />
                                        <DoubleTransition Property="Opacity" Duration="0:0:0.3" />
                                    </Transitions>
                                </TextBlock.Transitions>
                            </TextBlock>

                            <!-- Terminal progress bar: [//////.        ] filling
                                 as the phase elapses, monospace and phase-tinted. -->
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Spacing="10">
                                <TextBlock Text="{Binding Pomodoro.Gauge}" FontSize="20"
                                           Foreground="{Binding Pomodoro.Phase, Converter={StaticResource PhaseToBrush}}"
                                           Classes="timer" Classes.paused="{Binding Pomodoro.IsPaused}">
                                    <TextBlock.Transitions>
                                        <Transitions>
                                            <BrushTransition Property="Foreground" Duration="0:0:0.45" />
                                            <DoubleTransition Property="Opacity" Duration="0:0:0.3" />
                                        </Transitions>
                                    </TextBlock.Transitions>
                                </TextBlock>
                                <TextBlock Text="{Binding Pomodoro.PercentLabel}" Classes="caption"
                                           FontSize="14" VerticalAlignment="Center" />
                            </StackPanel>

                            <TextBlock Text="{Binding Pomodoro.RoundLabel}" Classes="caption"
                                       HorizontalAlignment="Center" />
                            <TextBlock Text="{Binding ActiveTaskLabel}" Classes="caption"
                                       Foreground="{DynamicResource MatchaBrush}"
                                       HorizontalAlignment="Center"
                                       IsVisible="{Binding HasActiveTask}" />
                        </StackPanel>
                    </Viewbox>

                    <!-- Session log (full mode) -->
                    <StackPanel Grid.Row="2" IsVisible="{Binding !SimpleTimer}">
                        <Border Height="1" Background="{DynamicResource BorderBrush}"
                                Margin="0,2,0,10" IsVisible="{Binding HasSessionLog}" />
                        <ItemsControl ItemsSource="{Binding SessionLog}"
                                      IsVisible="{Binding HasSessionLog}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="vm:TimerLogEntry">
                                    <Grid ColumnDefinitions="Auto,76,*" Margin="0,1,0,1">
                                        <TextBlock Grid.Column="0" Text="{Binding TimeLabel}" FontSize="12"
                                                   Foreground="{DynamicResource BorderBrush}" />
                                        <TextBlock Grid.Column="1" Text="{Binding PhaseLabel}" FontSize="12"
                                                   Margin="12,0,0,0"
                                                   Foreground="{Binding Phase, Converter={StaticResource PhaseToBrush}}" />
                                        <TextBlock Grid.Column="2" Text="{Binding Detail}" Classes="caption"
                                                   FontSize="12" Margin="8,0,0,0" />
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>

                    <!-- Controls: keybind footer (full) or plain buttons (simple) -->
                    <Grid Grid.Row="3" Margin="0,14,0,0">
                        <WrapPanel HorizontalAlignment="Center"
                                   IsVisible="{Binding !SimpleTimer}">
                            <Button Classes="keyhint" Command="{Binding Pomodoro.ToggleRunCommand}">
                                <TextBlock><Run Text="[space] " Foreground="{DynamicResource TextBrush}" /><Run Text="{Binding Pomodoro.StartPauseLabel}" /></TextBlock>
                            </Button>
                            <Button Classes="keyhint" Command="{Binding Pomodoro.ResetCommand}">
                                <TextBlock><Run Text="[r] " Foreground="{DynamicResource TextBrush}" /><Run Text="reset" /></TextBlock>
                            </Button>
                            <Button Classes="keyhint" Command="{Binding Pomodoro.SkipCommand}">
                                <TextBlock><Run Text="[s] " Foreground="{DynamicResource TextBrush}" /><Run Text="skip" /></TextBlock>
                            </Button>
                            <Button Classes="keyhint" Command="{Binding ToggleZenCommand}">
                                <TextBlock><Run Text="[z] " Foreground="{DynamicResource TextBrush}" /><Run Text="zen" /></TextBlock>
                            </Button>
                        </WrapPanel>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Spacing="12"
                                    IsVisible="{Binding SimpleTimer}">
                            <Button Content="{Binding Pomodoro.StartPauseLabel}" Classes="accent"
                                    Command="{Binding Pomodoro.ToggleRunCommand}" />
                            <Button Content="reset" Command="{Binding Pomodoro.ResetCommand}" />
                            <Button Content="skip" Command="{Binding Pomodoro.SkipCommand}" />
                        </StackPanel>
                    </Grid>
                </Grid>
            </Border>

            <!-- Tasks: a simple list by default; the .code editor is
                 hidden behind a power-user toggle. -->
            <Grid Grid.Column="1">
                <Border Classes="card">
                    <DockPanel>
                        <Grid DockPanel.Dock="Top" ColumnDefinitions="*,Auto,Auto">
                            <!-- Title + counter in one TextBlock so they share
                                 a single baseline regardless of font metrics. -->
                            <TextBlock Classes="jp" VerticalAlignment="Center">
                                <Run Text="課題 · tasks" />
                                <Run Text="   " />
                                <Run Text="{Binding Tasks.DoneCount, Mode=OneWay}" />
                                <Run Text=" / " />
                                <Run Text="{Binding Tasks.TotalCount, Mode=OneWay}" />
                            </TextBlock>

                            <ToggleButton Grid.Column="1" Classes="icon"
                                          IsChecked="{Binding Tasks.IsEditorVisible}"
                                          ToolTip.Tip="show / hide the .code editor"
                                          FontSize="12"
                                          Content="&lt;/&gt;" />
                            <Button Grid.Column="2" Classes="icon" Content="+" FontSize="18"
                                    Margin="2,0,0,0"
                                    Command="{Binding Tasks.OpenAddTaskCommand}"
                                    ToolTip.Tip="add a task" />
                        </Grid>

                        <!-- Optional .code editor — only when the toggle is on -->
                        <TextBox Classes="code" DockPanel.Dock="Bottom"
                                 Margin="0,12,0,0"
                                 IsVisible="{Binding Tasks.IsEditorVisible}"
                                 Text="{Binding Tasks.Source}"
                                 Watermark="// what do you want to get done?&#x0a;study: 25&#x0a;short: 5&#x0a;course: MATH101"
                                 AcceptsReturn="True"
                                 TextWrapping="Wrap"
                                 VerticalContentAlignment="Top" />

                        <!-- Empty state -->
                        <TextBlock DockPanel.Dock="Bottom" Text="課題はまだない · no tasks yet"
                                   Classes="jp" HorizontalAlignment="Center"
                                   Margin="0,16,0,8"
                                   IsVisible="{Binding !Tasks.HasTasks}" />

                        <!-- Parsed list — click a row to make it the active
                             task (click again to release it back to global
                             settings); tick the box to mark it done. -->
                        <ListBox ItemsSource="{Binding Tasks.Tasks}"
                                 SelectedItem="{Binding Tasks.ActiveTask}"
                                 SelectionMode="Single,Toggle"
                                 Classes="tasks"
                                 Margin="0,10,0,0"
                                 IsVisible="{Binding Tasks.HasTasks}">
                            <ListBox.ItemTemplate>
                                <DataTemplate x:DataType="m:TaskBlock">
                                    <Grid ColumnDefinitions="Auto,*,Auto,Auto">
                                        <CheckBox Grid.Column="0" IsChecked="{Binding IsDone, Mode=OneWay}"
                                                  Click="OnTaskDoneClick"
                                                  MinHeight="0" Padding="0"
                                                  VerticalAlignment="Center" Margin="0,0,8,0" />
                                        <TextBlock Grid.Column="1" Text="{Binding Title}"
                                                   Classes.done="{Binding IsDone}"
                                                   VerticalAlignment="Center" TextWrapping="Wrap" />
                                        <Border Grid.Column="2" Classes="tag" Margin="8,0,0,0"
                                                IsVisible="{Binding HasStudy}">
                                            <TextBlock Text="{Binding DurationsLabel}" />
                                        </Border>
                                        <Border Grid.Column="3" Classes="tag" Margin="6,0,0,0"
                                                IsVisible="{Binding HasCourse}">
                                            <TextBlock Text="{Binding Course}" Foreground="{Binding Course, Converter={StaticResource CourseColor}}" />
                                        </Border>
                                    </Grid>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </DockPanel>
                </Border>
            </Grid>
        </Grid>
    </Grid>
</UserControl>
