<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Tomoshibi.ViewModels"
             xmlns:m="using:Tomoshibi.Models"
             xmlns:conv="using:Tomoshibi.Converters"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             x:Class="Tomoshibi.Views.TimetableView"
             x:DataType="vm:TimetableViewModel">

    <UserControl.Resources>
        <conv:LowercaseConverter x:Key="Lower" />
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="28,4,28,28">
        <!-- Wide-capable: the week grid uses the extra width to give each day
             column real room on a big screen. -->
        <StackPanel MaxWidth="{StaticResource WidePageMaxWidth}">

            <!-- The whole schedule lives in one flat terminal panel -->
            <Border Classes="termpanel">
                <StackPanel Spacing="0">

                    <!-- Header -->
                    <Grid ColumnDefinitions="*,Auto" Margin="0,0,0,18">
                        <StackPanel Spacing="3">
                            <TextBlock Classes="path" Text="~/tomoshibi/timetable" />
                            <StackPanel Orientation="Horizontal" Spacing="10">
                                <TextBlock Text="❯" Classes="prompt" />
                                <TextBlock Text="schedule" Classes="h1" VerticalAlignment="Center" />
                            </StackPanel>
                            <TextBlock Text="{Binding ImportSummary}" Classes="caption"
                                       Margin="0,2,0,0"
                                       IsVisible="{Binding ImportSummary, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />
                        </StackPanel>

                        <Button Grid.Column="1" Content="$ import .ics" Classes="seg"
                                VerticalAlignment="Top" Margin="0,6,0,0"
                                Click="OnImportIcsClick"
                                ToolTip.Tip="bring in a timetable export — weekly events become classes, one-offs become deadlines" />
                    </Grid>

                    <!-- ============ Classes ============ -->
                    <Grid ColumnDefinitions="*,Auto,Auto,Auto">
                        <TextBlock Text="// 授業 · classes" Classes="jp" VerticalAlignment="Center" />
                        <Button Grid.Column="1" Classes="seg"
                                Classes.active="{Binding IsClassesGridView}"
                                Content="grid"
                                Command="{Binding ShowGridClassesCommand}" />
                        <Button Grid.Column="2" Classes="seg"
                                Classes.active="{Binding IsClassesListView}"
                                Content="list"
                                Command="{Binding ShowListClassesCommand}" />
                        <Button Grid.Column="3" Classes="icon"
                                Content="+" FontSize="18" Margin="8,0,0,0"
                                Command="{Binding OpenAddSlotCommand}"
                                ToolTip.Tip="add a class slot" />
                    </Grid>

                    <TextBlock Text="授業はまだない · no classes yet"
                               Classes="jp" Margin="0,14,0,0"
                               IsVisible="{Binding !HasSlots}" />

                    <!-- List view: the week read like a schedule config file -->
                    <StackPanel Margin="0,12,0,0" IsVisible="{Binding IsClassesListShown}">
                        <TextBlock Classes="caption" FontSize="12" Margin="2,0,0,6">
                            <Run Text="# schedule.tt · " />
                            <Run Text="{Binding SlotsLabel}" />
                        </TextBlock>
                        <ItemsControl ItemsSource="{Binding Slots}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="vm:ClassSlotItemViewModel">
                                    <Border Classes="trow" Margin="0,1,0,1" Cursor="Hand"
                                            PointerPressed="OnSlotPressed"
                                            ToolTip.Tip="click to edit">
                                        <Grid ColumnDefinitions="40,116,*,Auto,Auto">
                                            <TextBlock Grid.Column="0" Text="{Binding DayLabel}"
                                                       Foreground="{DynamicResource MutedTextBrush}"
                                                       VerticalAlignment="Center" />
                                            <TextBlock Grid.Column="1" Text="{Binding TimeLabel}"
                                                       VerticalAlignment="Center" />
                                            <TextBlock Grid.Column="2" Text="{Binding Title}"
                                                       VerticalAlignment="Center" TextWrapping="Wrap"
                                                       Margin="6,0,0,0" />
                                            <TextBlock Grid.Column="3" Text="{Binding Course}"
                                                       Foreground="{Binding Course, Converter={StaticResource CourseColor}}"
                                                       VerticalAlignment="Center" Margin="10,0,0,0"
                                                       IsVisible="{Binding HasCourse}" />
                                            <Button Grid.Column="4" Content="✕" Classes="icon" Margin="8,0,0,0"
                                                    Command="{Binding $parent[ItemsControl].((vm:TimetableViewModel)DataContext).RemoveSlotCommand}"
                                                    CommandParameter="{Binding}" />
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>

                    <!-- Week grid: time axis on the left, 7 day columns, slot
                         blocks placed via Grid.Row/Column on each ContentPresenter -->
                    <Grid Margin="0,14,0,0"
                          IsVisible="{Binding IsClassesGridShown}"
                          ColumnDefinitions="28,*,*,*,*,*,*,*"
                          RowDefinitions="22,38,38,38,38,38,38,38,38,38,38,38,38,38,38">

                        <TextBlock Grid.Row="0" Grid.Column="1" Text="mon" Classes="caption" HorizontalAlignment="Center" />
                        <TextBlock Grid.Row="0" Grid.Column="2" Text="tue" Classes="caption" HorizontalAlignment="Center" />
                        <TextBlock Grid.Row="0" Grid.Column="3" Text="wed" Classes="caption" HorizontalAlignment="Center" />
                        <TextBlock Grid.Row="0" Grid.Column="4" Text="thu" Classes="caption" HorizontalAlignment="Center" />
                        <TextBlock Grid.Row="0" Grid.Column="5" Text="fri" Classes="caption" HorizontalAlignment="Center" />
                        <TextBlock Grid.Row="0" Grid.Column="6" Text="sat" Classes="caption" HorizontalAlignment="Center" />
                        <TextBlock Grid.Row="0" Grid.Column="7" Text="sun" Classes="caption" HorizontalAlignment="Center" />

                        <TextBlock Grid.Row="1"  Grid.Column="0" Text="08" Classes="caption" VerticalAlignment="Top" />
                        <TextBlock Grid.Row="2"  Grid.Column="0" Text="09" Classes="caption" VerticalAlignment="Top" />
                        <TextBlock Grid.Row="3"  Grid.Column="0" Text="10" Classes="caption" VerticalAlignment="Top" />
                        <TextBlock Grid.Row="4"  Grid.Column="0" Text="11" Classes="caption" VerticalAlignment="Top" />
                        <TextBlock Grid.Row="5"  Grid.Column="0" Text="12" Classes="caption" VerticalAlignment="Top" />
                        <TextBlock Grid.Row="6"  Grid.Column="0" Text="13" Classes="caption" VerticalAlignment="Top" />
                        <TextBlock Grid.Row="7"  Grid.Column="0" Text="14" Classes="caption" VerticalAlignment="Top" />
                        <TextBlock Grid.Row="8"  Grid.Column="0" Text="15" Classes="caption" VerticalAlignment="Top" />
                        <TextBlock Grid.Row="9"  Grid.Column="0" Text="16" Classes="caption" VerticalAlignment="Top" />
                        <TextBlock Grid.Row="10" Grid.Column="0" Text="17" Classes="caption" VerticalAlignment="Top" />
                        <TextBlock Grid.Row="11" Grid.Column="0" Text="18" Classes="caption" VerticalAlignment="Top" />
                        <TextBlock Grid.Row="12" Grid.Column="0" Text="19" Classes="caption" VerticalAlignment="Top" />
                        <TextBlock Grid.Row="13" Grid.Column="0" Text="20" Classes="caption" VerticalAlignment="Top" />
                        <TextBlock Grid.Row="14" Grid.Column="0" Text="21" Classes="caption" VerticalAlignment="Top" />

                        <ItemsControl Grid.Row="1" Grid.RowSpan="14"
                                      Grid.Column="1" Grid.ColumnSpan="7"
                                      ItemsSource="{Binding Slots}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <Grid ColumnDefinitions="*,*,*,*,*,*,*"
                                          RowDefinitions="38,38,38,38,38,38,38,38,38,38,38,38,38,38" />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.Styles>
                                <Style Selector="ContentPresenter" x:DataType="vm:ClassSlotItemViewModel">
                                    <Setter Property="Grid.Row" Value="{Binding HourRow}" />
                                    <Setter Property="Grid.Column" Value="{Binding DayIndex}" />
                                    <Setter Property="Grid.RowSpan" Value="{Binding HourSpan}" />
                                </Style>
                            </ItemsControl.Styles>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="vm:ClassSlotItemViewModel">
                                    <Border Classes="slot" ToolTip.Tip="click to edit" Cursor="Hand"
                                            PointerPressed="OnSlotPressed"
                                            Background="{Binding Course, Converter={StaticResource CourseColor}, ConverterParameter=soft}"
                                            BorderBrush="{Binding Course, Converter={StaticResource CourseColor}}">
                                        <Grid>
                                            <StackPanel Margin="6,4,4,4" VerticalAlignment="Top">
                                                <TextBlock Text="{Binding Title}"
                                                           FontSize="11" FontWeight="SemiBold"
                                                           TextTrimming="CharacterEllipsis" />
                                                <TextBlock Text="{Binding Course}"
                                                           FontSize="10" Opacity="0.7"
                                                           IsVisible="{Binding HasCourse}"
                                                           TextTrimming="CharacterEllipsis" />
                                            </StackPanel>
                                            <Button Content="✕" Classes="icon"
                                                    FontSize="10" Padding="2,0"
                                                    HorizontalAlignment="Right" VerticalAlignment="Top"
                                                    Opacity="0.35"
                                                    Command="{Binding $parent[ItemsControl].((vm:TimetableViewModel)DataContext).RemoveSlotCommand}"
                                                    CommandParameter="{Binding}" />
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </Grid>

                    <!-- divider -->
                    <Border Height="1" Background="{DynamicResource BorderBrush}"
                            Margin="0,20,0,20" />

                    <!-- ============ Deadlines ============ -->
                    <Grid ColumnDefinitions="*,Auto">
                        <TextBlock Text="// 締切 · deadlines" Classes="jp" VerticalAlignment="Center" />
                        <Button x:Name="AddDeadlineButton" Grid.Column="1" Classes="icon"
                                Content="+" FontSize="18"
                                Click="OnAddDeadlineOpen"
                                ToolTip.Tip="add a deadline">
                            <Button.Flyout>
                                <Flyout Placement="BottomEdgeAlignedRight">
                                    <StackPanel Width="260" Spacing="10" Margin="8">
                                        <TextBlock Text="締切 · deadline" Classes="jp" />
                                        <CalendarDatePicker SelectedDate="{Binding NewDeadlineDate}" />
                                        <TextBox Watermark="what's due?"
                                                 Text="{Binding NewDeadlineTitle}" />
                                        <AutoCompleteBox Watermark="course"
                                                         Text="{Binding NewDeadlineCourse}"
                                                         ItemsSource="{Binding KnownCourses}"
                                                         FilterMode="Contains" />
                                        <Button Content="add" Classes="accent"
                                                HorizontalAlignment="Stretch"
                                                Command="{Binding AddDeadlineCommand}" />
                                        <TextBlock Text="lands on the todo backlog as a ticket"
                                                   Classes="caption" />
                                    </StackPanel>
                                </Flyout>
                            </Button.Flyout>
                        </Button>
                    </Grid>

                    <TextBlock Text="締切はまだない · no deadlines yet"
                               Classes="jp" Margin="0,12,0,0"
                               IsVisible="{Binding !HasDeadlines}" />

                    <ItemsControl ItemsSource="{Binding Deadlines}" Margin="0,8,0,0">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="vm:DeadlineItemViewModel">
                                <Border Classes="trow" Margin="0,1,0,1">
                                    <Grid ColumnDefinitions="92,Auto,*,Auto,Auto">
                                        <TextBlock Grid.Column="0" Text="{Binding DateLabel}"
                                                   Classes="caption" VerticalAlignment="Center"
                                                   Classes.overdue="{Binding IsOverdue}" />
                                        <TextBlock Grid.Column="1" Text="{Binding NumberLabel}"
                                                   Classes="caption" VerticalAlignment="Center"
                                                   Margin="0,0,8,0"
                                                   ToolTip.Tip="a todo ticket — edit it on the todo page" />
                                        <TextBlock Grid.Column="2" Text="{Binding Title}"
                                                   VerticalAlignment="Center" TextWrapping="Wrap" />
                                        <TextBlock Grid.Column="3" Text="{Binding Course}"
                                                   Foreground="{Binding Course, Converter={StaticResource CourseColor}}"
                                                   VerticalAlignment="Center" Margin="10,0,0,0"
                                                   IsVisible="{Binding HasCourse}" />
                                        <Button Grid.Column="4" Content="✕" Classes="icon" Margin="6,0,0,0"
                                                ToolTip.Tip="delete the ticket"
                                                Command="{Binding $parent[ItemsControl].((vm:TimetableViewModel)DataContext).RemoveDeadlineCommand}"
                                                CommandParameter="{Binding}" />
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <!-- ============ Upcoming exams (from the subjects page) ============ -->
                    <Border Height="1" Background="{DynamicResource BorderBrush}"
                            Margin="0,20,0,20" IsVisible="{Binding HasUpcomingExams}" />
                    <TextBlock Text="// 試験 · upcoming exams" Classes="jp"
                               IsVisible="{Binding HasUpcomingExams}" />
                    <ItemsControl ItemsSource="{Binding UpcomingExams}" Margin="0,6,0,0"
                                  IsVisible="{Binding HasUpcomingExams}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding}" FontSize="13" Margin="0,2,0,0" />
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</UserControl>
