<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Tomoshibi.ViewModels"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             x:Class="Tomoshibi.Views.ReviewView"
             x:DataType="vm:ReviewViewModel">

    <Grid>

    <!-- ================= Decks (master + detail) ================= -->
    <Grid IsVisible="{Binding !IsReviewing}">

        <!-- Master: deck list -->
        <ScrollViewer IsVisible="{Binding !IsDeckOpen}" VerticalScrollBarVisibility="Auto">
            <StackPanel Spacing="14" Margin="28,4,28,28" MaxWidth="760">

                <Grid ColumnDefinitions="*,Auto,Auto" Margin="0,0,0,4">
                    <StackPanel Spacing="3">
                        <TextBlock Classes="path" Text="~/tomoshibi/review" />
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <TextBlock Text="❯" Classes="prompt" />
                            <TextBlock Text="復習 · review" Classes="h1 cjk" VerticalAlignment="Center" />
                        </StackPanel>
                        <TextBlock Text="{Binding SummaryLabel}" Classes="caption" Margin="0,2,0,0"
                                   TextWrapping="Wrap" />
                        <TextBlock Text="{Binding ImportSummary}" Classes="caption" Margin="0,2,0,0"
                                   TextWrapping="Wrap"
                                   IsVisible="{Binding ImportSummary, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />
                    </StackPanel>
                    <Button Grid.Column="1" Classes="seg" Content="import"
                            VerticalAlignment="Top" Margin="0,0,8,0"
                            Click="OnImportDeckClick"
                            ToolTip.Tip="bring in an Anki text export — the first two columns become front and back" />
                    <Button Grid.Column="2" Classes="accent" Content="review all due"
                            VerticalAlignment="Top"
                            Command="{Binding ReviewAllCommand}"
                            IsVisible="{Binding HasDue}" />
                </Grid>

                <ItemsControl ItemsSource="{Binding Decks}" IsVisible="{Binding HasDecks}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="vm:DeckViewModel">
                            <Border Classes="card" Margin="0,0,0,10" Padding="18,14">
                                <Grid ColumnDefinitions="*,Auto,Auto,Auto">
                                    <StackPanel Grid.Column="0" Spacing="6" VerticalAlignment="Center">
                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                            <TextBlock Text="▸" VerticalAlignment="Center"
                                                       Foreground="{DynamicResource MatchaBrush}" />
                                            <TextBlock Text="{Binding Name}" FontWeight="SemiBold"
                                                       VerticalAlignment="Center" />
                                            <Border Classes="tag" VerticalAlignment="Center"
                                                    IsVisible="{Binding HasCourse}">
                                                <TextBlock Text="{Binding Course}"
                                                           Foreground="{Binding Course, Converter={StaticResource CourseColor}}" />
                                            </Border>
                                        </StackPanel>
                                        <StackPanel Orientation="Horizontal" Spacing="10">
                                            <TextBlock Text="{Binding DueBar}" FontSize="12"
                                                       FontFamily="{DynamicResource MonoFont}"
                                                       Classes="duebar" Classes.caughtup="{Binding !HasDue}"
                                                       VerticalAlignment="Center" />
                                            <TextBlock Text="{Binding CountsLabel}" Classes="caption"
                                                       VerticalAlignment="Center" />
                                        </StackPanel>
                                    </StackPanel>
                                    <Button Grid.Column="1" Classes="seg" Content="review"
                                            Command="{Binding $parent[ItemsControl].((vm:ReviewViewModel)DataContext).ReviewDeckCommand}"
                                            CommandParameter="{Binding}"
                                            IsVisible="{Binding HasDue}" />
                                    <Button Grid.Column="2" Classes="seg" Content="edit"
                                            Command="{Binding $parent[ItemsControl].((vm:ReviewViewModel)DataContext).OpenDeckCommand}"
                                            CommandParameter="{Binding}" />
                                    <Button Grid.Column="3" Classes="icon" Content="✕"
                                            ToolTip.Tip="delete deck"
                                            Command="{Binding $parent[ItemsControl].((vm:ReviewViewModel)DataContext).DeleteDeckCommand}"
                                            CommandParameter="{Binding}" />
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <TextBlock Text="デッキはまだない · no decks yet"
                           Classes="jp" HorizontalAlignment="Center" Margin="0,40,0,8"
                           IsVisible="{Binding !HasDecks}" />

                <!-- Add deck -->
                <Border Classes="card">
                    <StackPanel Spacing="10">
                        <TextBlock Text="// 新しいデッキ · new deck" Classes="jp" />
                        <Grid ColumnDefinitions="*,140,Auto">
                            <TextBox Grid.Column="0" Text="{Binding NewDeckName}"
                                     Watermark="deck name…" FontSize="13" Padding="10,6">
                                <TextBox.KeyBindings>
                                    <KeyBinding Gesture="Enter" Command="{Binding AddDeckCommand}" />
                                </TextBox.KeyBindings>
                            </TextBox>
                            <TextBox Grid.Column="1" Text="{Binding NewDeckCourse}"
                                     Watermark="course" Margin="6,0,0,0" FontSize="13" Padding="10,6" />
                            <Button Grid.Column="2" Content="+" Classes="icon" Margin="4,0,0,0"
                                    Command="{Binding AddDeckCommand}" />
                        </Grid>
                        <TextBlock Text="tag a deck with a course code to tie it to a subject"
                                   Classes="caption" />
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <!-- Detail: deck editor -->
        <ScrollViewer IsVisible="{Binding IsDeckOpen}" VerticalScrollBarVisibility="Auto">
            <StackPanel Spacing="16" Margin="28,4,28,28" MaxWidth="760">

                <Grid ColumnDefinitions="Auto,*,Auto,Auto">
                    <Button Grid.Column="0" Classes="icon" Content="←" FontSize="18"
                            VerticalAlignment="Top" Margin="0,2,8,0"
                            Command="{Binding CloseDeckCommand}"
                            ToolTip.Tip="back to decks · esc" />
                    <TextBlock Grid.Column="1" Text="// デッキ · deck" Classes="jp"
                               VerticalAlignment="Center" />
                    <Button Grid.Column="2" Classes="seg" Content="export"
                            VerticalAlignment="Top" Margin="0,0,8,0"
                            Click="OnExportDeckClick"
                            IsVisible="{Binding SelectedDeck.HasCards}"
                            ToolTip.Tip="save this deck as Anki-importable text" />
                    <Button Grid.Column="3" Classes="accent" Content="review"
                            VerticalAlignment="Top"
                            Command="{Binding ReviewDeckCommand}"
                            CommandParameter="{Binding SelectedDeck}"
                            IsVisible="{Binding SelectedDeck.HasDue}" />
                </Grid>

                <StackPanel Spacing="16" DataContext="{Binding SelectedDeck}"
                            x:DataType="vm:DeckViewModel">

                    <Border Classes="card">
                        <StackPanel Spacing="10">
                            <TextBox Text="{Binding Name}" Watermark="deck name" FontSize="16" />
                            <Grid ColumnDefinitions="*,160">
                                <TextBlock Text="{Binding CountsLabel}" Classes="caption"
                                           VerticalAlignment="Center" />
                                <TextBox Grid.Column="1" Text="{Binding Course}"
                                         Watermark="course code" FontSize="13" Padding="10,6" />
                            </Grid>
                        </StackPanel>
                    </Border>

                    <Border Classes="card">
                        <StackPanel Spacing="10">
                            <TextBlock Text="// カード · cards" Classes="jp" />

                            <ItemsControl ItemsSource="{Binding Cards}" IsVisible="{Binding HasCards}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate x:DataType="vm:FlashcardViewModel">
                                        <Grid ColumnDefinitions="*,*,Auto" Margin="0,3,0,0">
                                            <TextBox Grid.Column="0" Text="{Binding Front}"
                                                     Watermark="front" FontSize="13" Padding="10,6"
                                                     AcceptsReturn="True" TextWrapping="Wrap" />
                                            <TextBox Grid.Column="1" Text="{Binding Back}"
                                                     Watermark="back" Margin="6,0,0,0"
                                                     FontSize="13" Padding="10,6"
                                                     AcceptsReturn="True" TextWrapping="Wrap" />
                                            <Button Grid.Column="2" Content="✕" Classes="icon"
                                                    FontSize="11" Padding="4,2" Margin="4,0,0,0"
                                                    Command="{Binding $parent[ItemsControl].((vm:DeckViewModel)DataContext).RemoveCardCommand}"
                                                    CommandParameter="{Binding}" />
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <TextBlock Text="add a few cards — the front prompts you, the back is the answer"
                                       Classes="caption" IsVisible="{Binding !HasCards}" />

                            <Grid ColumnDefinitions="*,*,Auto">
                                <TextBox Grid.Column="0" Text="{Binding NewCardFront}"
                                         Watermark="front" FontSize="13" Padding="10,6" />
                                <TextBox Grid.Column="1" Text="{Binding NewCardBack}"
                                         Watermark="back" Margin="6,0,0,0" FontSize="13" Padding="10,6">
                                    <TextBox.KeyBindings>
                                        <KeyBinding Gesture="Enter" Command="{Binding AddCardCommand}" />
                                    </TextBox.KeyBindings>
                                </TextBox>
                                <Button Grid.Column="2" Content="+" Classes="icon" Margin="4,0,0,0"
                                        Command="{Binding AddCardCommand}" />
                            </Grid>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </StackPanel>
        </ScrollViewer>
    </Grid>

    <!-- ================= Review session ================= -->
    <Grid IsVisible="{Binding IsReviewing}" RowDefinitions="Auto,*,Auto" Margin="28">

        <!-- Top bar: scope + ascii progress meter + end -->
        <Grid Grid.Row="0" ColumnDefinitions="*,Auto" IsVisible="{Binding !IsSessionDone}">
            <StackPanel Spacing="6" VerticalAlignment="Center">
                <TextBlock Text="{Binding ProgressLabel}" Classes="jp" />
                <TextBlock Text="{Binding ProgressBar}" FontSize="13"
                           FontFamily="{DynamicResource MonoFont}"
                           Foreground="{DynamicResource MatchaBrush}" />
            </StackPanel>
            <Button Grid.Column="1" Classes="seg" Content="end" VerticalAlignment="Top"
                    Command="{Binding EndReviewCommand}" />
        </Grid>

        <!-- The card: terminal Q/A, left-aligned with // markers -->
        <Border Grid.Row="1" Classes="card" Margin="0,16,0,16" Padding="28"
                VerticalAlignment="Center" MaxWidth="620"
                IsVisible="{Binding !IsSessionDone}">
            <StackPanel Spacing="14">
                <TextBlock Text="// 問 · prompt" Classes="jp" />
                <TextBlock Text="{Binding CardFront}" FontSize="20" TextWrapping="Wrap" />
                <Border Height="1" Background="{DynamicResource BorderBrush}" Margin="0,4"
                        IsVisible="{Binding IsFlipped}" />
                <TextBlock Text="// 答 · answer" Classes="jp" IsVisible="{Binding IsFlipped}" />
                <TextBlock Text="{Binding CardBack}" FontSize="17" TextWrapping="Wrap"
                           Foreground="{DynamicResource MatchaBrush}"
                           IsVisible="{Binding IsFlipped}" />
            </StackPanel>
        </Border>

        <!-- Done state -->
        <StackPanel Grid.Row="1" VerticalAlignment="Center" HorizontalAlignment="Center"
                    Spacing="12" IsVisible="{Binding IsSessionDone}">
            <TextBlock Text="お疲れ様 · all done" Classes="jp" HorizontalAlignment="Center" />
            <TextBlock Text="{Binding SessionDoneLabel}" FontSize="22" FontWeight="SemiBold"
                       HorizontalAlignment="Center" />
            <Button Classes="accent" Content="back to decks" HorizontalAlignment="Center"
                    Command="{Binding EndReviewCommand}" />
        </StackPanel>

        <!-- Controls: keyboard-driven — space reveals, 1/2/3 grade -->
        <StackPanel Grid.Row="2" HorizontalAlignment="Center"
                    IsVisible="{Binding !IsSessionDone}">
            <Button Classes="accent" HorizontalAlignment="Center"
                    Command="{Binding FlipCommand}" IsVisible="{Binding !IsFlipped}">
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <Border Classes="kbd"><TextBlock Text="space" /></Border>
                    <TextBlock Text="show answer" VerticalAlignment="Center" />
                </StackPanel>
            </Button>
            <StackPanel Orientation="Horizontal" Spacing="10" HorizontalAlignment="Center"
                        IsVisible="{Binding IsFlipped}">
                <Button Command="{Binding GradeAgainCommand}"
                        ToolTip.Tip="missed it — see it again soon">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <Border Classes="kbd"><TextBlock Text="1" /></Border>
                        <TextBlock Text="again" VerticalAlignment="Center" />
                    </StackPanel>
                </Button>
                <Button Classes="accent" Command="{Binding GradeGoodCommand}"
                        ToolTip.Tip="recalled it">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <Border Classes="kbd"><TextBlock Text="2" /></Border>
                        <TextBlock Text="good" VerticalAlignment="Center" />
                    </StackPanel>
                </Button>
                <Button Command="{Binding GradeEasyCommand}"
                        ToolTip.Tip="too easy — push it further out">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <Border Classes="kbd"><TextBlock Text="3" /></Border>
                        <TextBlock Text="easy" VerticalAlignment="Center" />
                    </StackPanel>
                </Button>
            </StackPanel>
        </StackPanel>
    </Grid>

    </Grid>
</UserControl>
