<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Tomoshibi.ViewModels"
             xmlns:conv="using:Tomoshibi.Converters"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             x:Class="Tomoshibi.Views.SubjectsView"
             x:DataType="vm:SubjectsViewModel">

    <UserControl.Resources>
        <conv:StringToPointsConverter x:Key="ToPoints" />
        <conv:RingDashConverter x:Key="RingDash" />
    </UserControl.Resources>

    <Grid>

    <!-- ================= Master: subjects by term ================= -->
    <Grid RowDefinitions="Auto,*" Margin="28,4,28,28" MaxWidth="760"
          IsVisible="{Binding !IsDetailOpen}">

        <!-- Page header -->
        <Grid Grid.Row="0" ColumnDefinitions="*,Auto" Margin="0,0,0,16">
            <StackPanel Spacing="2">
                <TextBlock Text="科目 · subjects" Classes="jp" />
                <TextBlock Text="{Binding GpaLabel}" Classes="h1" />
                <TextBlock Text="{Binding GpaCaption}" Classes="caption"
                           IsVisible="{Binding GpaCaption, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />
            </StackPanel>

            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8"
                        VerticalAlignment="Top">
                <ComboBox ItemsSource="{Binding ScaleOptions}"
                          SelectedItem="{Binding SelectedScale}"
                          MinWidth="130" Padding="10,6"
                          ToolTip.Tip="grading scale — grades are always entered as percentages" />
                <Button Classes="seg" Content="export"
                        Click="OnExportClick"
                        ToolTip.Tip="save a markdown transcript" />
                <Button Classes="accent" Content="+ new"
                        Command="{Binding OpenAddCommand}" />
            </StackPanel>
        </Grid>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel Spacing="4">

                <!-- Degree projection -->
                <Border Classes="card" Margin="0,0,0,12"
                        IsVisible="{Binding HasDegreeProjection}">
                    <StackPanel Spacing="8">
                        <TextBlock Text="学位 · degree" Classes="jp" />
                        <TextBlock Text="{Binding DegreeLabel}" FontSize="18" FontWeight="SemiBold" />
                        <TextBlock Text="{Binding DegreeCaption}" Classes="caption" />
                        <ItemsControl ItemsSource="{Binding YearWeights}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="vm:YearWeightViewModel">
                                    <Grid ColumnDefinitions="80,80,*,110" Margin="0,4,0,0">
                                        <TextBlock Grid.Column="0" Text="{Binding YearLabel}"
                                                   Classes="caption" VerticalAlignment="Center" />
                                        <TextBlock Grid.Column="1" Text="{Binding AverageLabel}"
                                                   VerticalAlignment="Center" FontSize="13" />
                                        <NumericUpDown Grid.Column="3" Value="{Binding Weight}"
                                                       Watermark="weight %"
                                                       Minimum="0" Maximum="100" FormatString="0.#"
                                                       FontSize="13" Padding="10,5"
                                                       ToolTip.Tip="how much this year counts toward the degree" />
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>

                <!-- Term groups -->
                <ItemsControl ItemsSource="{Binding Groups}"
                              IsVisible="{Binding HasSubjects}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="vm:TermGroupViewModel">
                            <StackPanel>
                                <Grid ColumnDefinitions="*,Auto" Margin="2,8,2,8"
                                      IsVisible="{Binding Header, Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
                                    <TextBlock Text="{Binding Header}" Classes="jp" />
                                    <TextBlock Grid.Column="1" Text="{Binding AverageLabel}"
                                               Classes="caption" IsVisible="{Binding HasAverage}" />
                                </Grid>

                                <ItemsControl ItemsSource="{Binding Items}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate x:DataType="vm:SubjectViewModel">
                                            <Border Classes="card subjcard" Margin="0,0,0,12" Padding="18,14"
                                                    PointerPressed="OnCardPressed">
                                                <StackPanel Spacing="10">
                                                <Grid ColumnDefinitions="*,Auto,Auto,Auto,Auto,Auto,Auto,Auto">
                                                    <StackPanel Grid.Column="0" Spacing="2" VerticalAlignment="Center">
                                                        <TextBlock Text="{Binding Name}" FontWeight="SemiBold"
                                                                   TextWrapping="Wrap" />
                                                        <TextBlock Text="{Binding StandingCaption}" Classes="caption"
                                                                   IsVisible="{Binding StandingCaption, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />
                                                    </StackPanel>
                                                    <Border Grid.Column="1" Classes="tag" Margin="8,0,0,0"
                                                            IsVisible="{Binding HasCode}">
                                                        <TextBlock Text="{Binding Code}" Foreground="{Binding Code, Converter={StaticResource CourseColor}}" />
                                                    </Border>
                                                    <Border Grid.Column="2" Classes="tag prio" Margin="6,0,0,0"
                                                            Classes.high="{Binding IsTargetAtRisk}"
                                                            IsVisible="{Binding HasTarget}">
                                                        <TextBlock Text="{Binding TargetChip}" />
                                                    </Border>
                                                    <TextBlock Grid.Column="3" Text="{Binding CreditsLabel}"
                                                               Classes="caption" Margin="8,0,0,0"
                                                               VerticalAlignment="Center" />
                                                    <TextBlock Grid.Column="4" Text="{Binding GradeLabel}"
                                                               Margin="14,0,0,0" VerticalAlignment="Center"
                                                               Classes="grade"
                                                               Classes.ggood="{Binding IsStandingGood}"
                                                               Classes.gwarn="{Binding IsStandingWarn}"
                                                               Classes.gbad="{Binding IsStandingBad}"
                                                               FontWeight="SemiBold" FontSize="16" />
                                                    <Border Grid.Column="5" Classes="tag" Margin="6,0,0,0"
                                                            IsVisible="{Binding HasGrade}">
                                                        <TextBlock Text="{Binding LetterLabel}" />
                                                    </Border>
                                                    <Button Grid.Column="6" Content="✎" Classes="icon" Margin="8,0,0,0"
                                                            ToolTip.Tip="edit subject"
                                                            Click="OnEditClick" />
                                                    <Button Grid.Column="7" Content="✕" Classes="icon"
                                                            ToolTip.Tip="delete subject"
                                                            Command="{Binding $parent[UserControl].((vm:SubjectsViewModel)DataContext).RemoveCommand}"
                                                            CommandParameter="{Binding}" />
                                                </Grid>

                                                <!-- How much of the module has results -->
                                                <Grid ColumnDefinitions="*,Auto"
                                                      IsVisible="{Binding HasAssessments}">
                                                    <ProgressBar Value="{Binding GradedShare}" Minimum="0" Maximum="1"
                                                                 Height="3" MinHeight="0"
                                                                 Foreground="{DynamicResource BlueBrush}"
                                                                 Background="{DynamicResource SurfaceHoverBrush}" />
                                                    <TextBlock Grid.Column="1" Text="{Binding GradedShareCaption}"
                                                               Classes="caption" Margin="10,0,0,0" FontSize="10" />
                                                </Grid>
                                                </StackPanel>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <TextBlock Text="科目はまだない · no subjects yet"
                           Classes="jp" HorizontalAlignment="Center"
                           Margin="0,80,0,0"
                           IsVisible="{Binding !HasSubjects}" />
            </StackPanel>
        </ScrollViewer>
    </Grid>

    <!-- ================= Detail: one subject ================= -->
    <ScrollViewer IsVisible="{Binding IsDetailOpen}" VerticalScrollBarVisibility="Auto">
        <StackPanel Spacing="16" Margin="28,4,28,28" MaxWidth="760">
            <StackPanel Spacing="16" DataContext="{Binding SelectedSubject}"
                        x:DataType="vm:SubjectViewModel">

                <!-- Detail header -->
                <Grid ColumnDefinitions="Auto,*,Auto">
                    <Button Grid.Column="0" Classes="icon" Content="←" FontSize="18"
                            VerticalAlignment="Top" Margin="0,2,8,0"
                            Command="{Binding $parent[UserControl].((vm:SubjectsViewModel)DataContext).CloseDetailCommand}"
                            ToolTip.Tip="back to subjects · esc" />
                    <StackPanel Grid.Column="1" Spacing="2">
                        <TextBlock Text="{Binding TermLabel}" Classes="jp" />
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <TextBlock Text="{Binding Name}" Classes="h1" />
                            <Border Classes="tag" VerticalAlignment="Center"
                                    IsVisible="{Binding HasCode}">
                                <TextBlock Text="{Binding Code}" Foreground="{Binding Code, Converter={StaticResource CourseColor}}" />
                            </Border>
                            <Border Classes="tag prio" VerticalAlignment="Center"
                                    Classes.high="{Binding IsTargetAtRisk}"
                                    IsVisible="{Binding HasTarget}">
                                <TextBlock Text="{Binding TargetChip}" />
                            </Border>
                            <TextBlock Text="{Binding CreditsLabel}" Classes="caption"
                                       VerticalAlignment="Center" />
                        </StackPanel>
                    </StackPanel>
                    <Button Grid.Column="2" Classes="icon" Content="✎" FontSize="16"
                            VerticalAlignment="Top"
                            ToolTip.Tip="edit subject"
                            Click="OnEditClick" />
                </Grid>

                <!-- Standing -->
                <Border Classes="card">
                    <StackPanel Spacing="10">
                        <TextBlock Text="成績 · standing" Classes="jp" />
                        <StackPanel Orientation="Horizontal" Spacing="24"
                                    HorizontalAlignment="Center" Margin="0,4,0,0">

                            <!-- Standing ring -->
                            <Grid Width="104" Height="104">
                                <Ellipse Width="98" Height="98"
                                         Stroke="{DynamicResource SurfaceHoverBrush}"
                                         StrokeThickness="6" />
                                <Ellipse Width="98" Height="98"
                                         Classes="ring"
                                         Classes.ggood="{Binding IsStandingGood}"
                                         Classes.gwarn="{Binding IsStandingWarn}"
                                         Classes.gbad="{Binding IsStandingBad}"
                                         StrokeThickness="6" StrokeLineCap="Round"
                                         StrokeDashArray="{Binding StandingFraction, Converter={StaticResource RingDash}, ConverterParameter='46,6'}" />
                                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                    <TextBlock Text="{Binding GradeLabel}" FontSize="19" FontWeight="SemiBold"
                                               HorizontalAlignment="Center"
                                               Classes="grade"
                                               Classes.ggood="{Binding IsStandingGood}"
                                               Classes.gwarn="{Binding IsStandingWarn}"
                                               Classes.gbad="{Binding IsStandingBad}" />
                                    <TextBlock Text="{Binding LetterLabel}" Classes="caption"
                                               HorizontalAlignment="Center"
                                               IsVisible="{Binding HasGrade}" />
                                </StackPanel>
                            </Grid>

                            <StackPanel VerticalAlignment="Center" Spacing="6" Width="220">
                                <TextBlock Text="{Binding GradeLabel}" FontSize="30" FontWeight="Light"
                                           Classes="grade"
                                           Classes.ggood="{Binding IsStandingGood}"
                                           Classes.gwarn="{Binding IsStandingWarn}"
                                           Classes.gbad="{Binding IsStandingBad}" />
                                <TextBlock Text="{Binding PointsLabel}" Classes="caption"
                                           IsVisible="{Binding PointsLabel, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />
                                <ProgressBar Value="{Binding GradedShare}" Minimum="0" Maximum="1"
                                             Height="4" MinHeight="0" Margin="0,4,0,0"
                                             Foreground="{DynamicResource BlueBrush}"
                                             Background="{DynamicResource SurfaceHoverBrush}" />
                                <TextBlock Text="{Binding GradedShareCaption}"
                                           Classes="caption" FontSize="10" />
                            </StackPanel>
                        </StackPanel>

                        <TextBlock Text="{Binding SimulationLabel}" FontSize="13"
                                   Foreground="{DynamicResource AmberBrush}"
                                   IsVisible="{Binding HasSimulation}" />

                        <Polyline Points="{Binding SparkPoints, Converter={StaticResource ToPoints}}"
                                  Stroke="{DynamicResource MatchaBrush}" StrokeThickness="2"
                                  Width="220" Height="48" HorizontalAlignment="Left"
                                  IsVisible="{Binding HasSpark}"
                                  ToolTip.Tip="standing over time, by assessment date" />

                        <TextBlock Text="{Binding StandingCaption}" Classes="caption"
                                   IsVisible="{Binding StandingCaption, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />
                        <TextBlock Text="{Binding DropRulesCaption}" Classes="caption"
                                   IsVisible="{Binding HasDropRules}" />
                        <TextBlock Text="{Binding WeightWarning}" Classes="caption overest"
                                   IsVisible="{Binding HasWeightWarning}" />
                    </StackPanel>
                </Border>

                <!-- Outlook -->
                <Border Classes="card" IsVisible="{Binding HasOutlook}">
                    <StackPanel Spacing="8">
                        <TextBlock Text="見通し · outlook" Classes="jp" />
                        <ItemsControl ItemsSource="{Binding OutlookLines}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding}" FontSize="13" Margin="0,2,0,0" />
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>

                <!-- Assessments -->
                <Border Classes="card">
                    <StackPanel Spacing="10">
                        <Grid ColumnDefinitions="*,Auto">
                            <TextBlock Text="評価 · assessments" Classes="jp" VerticalAlignment="Center" />
                            <Button Grid.Column="1" Classes="seg" Content="simulate"
                                    Classes.active="{Binding IsSimulating}"
                                    Command="{Binding ToggleSimulationCommand}"
                                    ToolTip.Tip="try hypothetical grades on ungraded work — nothing is saved" />
                        </Grid>

                        <ItemsControl ItemsSource="{Binding Assessments}"
                                      IsVisible="{Binding HasAssessments}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="vm:AssessmentViewModel">
                                    <Grid ColumnDefinitions="*,Auto,Auto,Auto,Auto,Auto,Auto" Margin="0,3,0,0">
                                        <TextBlock Grid.Column="0" Text="{Binding Title}"
                                                   VerticalAlignment="Center" TextWrapping="Wrap" />
                                        <TextBlock Grid.Column="1" Text="{Binding DateLabel}"
                                                   Classes="caption" Margin="8,0,0,0"
                                                   VerticalAlignment="Center"
                                                   IsVisible="{Binding HasDate}" />
                                        <Border Grid.Column="2" Classes="tag prio" Margin="8,0,0,0"
                                                IsVisible="{Binding HasCategory}">
                                            <TextBlock Text="{Binding Category}" />
                                        </Border>
                                        <Border Grid.Column="3" Classes="tag" Margin="6,0,0,0">
                                            <TextBlock Text="{Binding WeightLabel}" />
                                        </Border>
                                        <NumericUpDown Grid.Column="4" Value="{Binding SimGrade}"
                                                       Watermark="what if…" Width="100" Margin="8,0,0,0"
                                                       Minimum="0" Maximum="100" FormatString="0.#"
                                                       FontSize="13" Padding="10,5"
                                                       BorderBrush="{DynamicResource AmberBrush}"
                                                       IsVisible="{Binding IsSimVisible}"
                                                       ToolTip.Tip="hypothetical — not saved" />
                                        <NumericUpDown Grid.Column="5" Value="{Binding Grade}"
                                                       Watermark="—" Width="92" Margin="8,0,0,0"
                                                       Minimum="0" Maximum="100" FormatString="0.#"
                                                       FontSize="13" Padding="10,5"
                                                       ToolTip.Tip="grade in percent — type it when results land" />
                                        <Button Grid.Column="6" Content="✕" Classes="icon"
                                                FontSize="11" Padding="4,2" Margin="4,0,0,0"
                                                Command="{Binding $parent[ItemsControl].((vm:SubjectViewModel)DataContext).RemoveAssessmentCommand}"
                                                CommandParameter="{Binding}" />
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <TextBlock Text="add the syllabus pieces — exam 40%, essay 30%…"
                                   Classes="caption"
                                   IsVisible="{Binding !HasAssessments}" />

                        <!-- Add assessment -->
                        <Grid ColumnDefinitions="*,84,76,76,128,Auto">
                            <TextBox Grid.Column="0" Text="{Binding NewTitle}"
                                     Watermark="exam, essay, lab…"
                                     FontSize="13" Padding="10,6">
                                <TextBox.KeyBindings>
                                    <KeyBinding Gesture="Enter" Command="{Binding AddAssessmentCommand}" />
                                </TextBox.KeyBindings>
                            </TextBox>
                            <TextBox Grid.Column="1" Text="{Binding NewCategory}"
                                     Watermark="category" Margin="6,0,0,0"
                                     FontSize="13" Padding="10,6"
                                     ToolTip.Tip="optional — what drop rules target, e.g. quiz" />
                            <NumericUpDown Grid.Column="2" Value="{Binding NewWeight}"
                                           Watermark="wt %" Margin="6,0,0,0"
                                           Minimum="1" Maximum="100" FormatString="0.#"
                                           FontSize="13" Padding="10,5" />
                            <NumericUpDown Grid.Column="3" Value="{Binding NewGrade}"
                                           Watermark="grade" Margin="6,0,0,0"
                                           Minimum="0" Maximum="100" FormatString="0.#"
                                           FontSize="13" Padding="10,5"
                                           ToolTip.Tip="optional — leave empty until results land" />
                            <CalendarDatePicker Grid.Column="4" SelectedDate="{Binding NewDate}"
                                                Watermark="date" Margin="6,0,0,0"
                                                FontSize="13" />
                            <Button Grid.Column="5" Content="+" Classes="icon" Margin="4,0,0,0"
                                    Command="{Binding AddAssessmentCommand}" />
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Resources -->
                <Border Classes="card">
                    <StackPanel Spacing="10">
                        <TextBlock Text="資料 · resources" Classes="jp" />

                        <ItemsControl ItemsSource="{Binding Resources}" IsVisible="{Binding HasResources}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="vm:StudyLinkViewModel">
                                    <Border Classes="trow" Margin="0,2,0,0">
                                        <Grid ColumnDefinitions="*,Auto,Auto">
                                            <TextBlock Text="{Binding Title}" VerticalAlignment="Center"
                                                       TextTrimming="CharacterEllipsis" />
                                            <Button Grid.Column="1" Content="▶ open" Classes="seg"
                                                    Command="{Binding OpenCommand}"
                                                    ToolTip.Tip="open in your browser" />
                                            <Button Grid.Column="2" Content="✕" Classes="icon"
                                                    Command="{Binding RemoveCommand}" />
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <Grid ColumnDefinitions="*,1.4*,Auto">
                            <TextBox Grid.Column="0" Text="{Binding NewResourceTitle}"
                                     Watermark="label" FontSize="13" Padding="10,6" />
                            <TextBox Grid.Column="1" Text="{Binding NewResourceUrl}"
                                     Watermark="slides / syllabus / drive url…" Margin="6,0,0,0"
                                     FontSize="13" Padding="10,6">
                                <TextBox.KeyBindings>
                                    <KeyBinding Gesture="Enter" Command="{Binding AddResourceCommand}" />
                                </TextBox.KeyBindings>
                            </TextBox>
                            <Button Grid.Column="2" Content="+" Classes="icon" Margin="4,0,0,0"
                                    Command="{Binding AddResourceCommand}" />
                        </Grid>
                        <TextBlock Text="links open in your browser — keep the course's slides and drive here"
                                   Classes="caption" />
                    </StackPanel>
                </Border>

                <!-- Notes -->
                <Border Classes="card">
                    <StackPanel Spacing="10">
                        <TextBlock Text="メモ · notes" Classes="jp" />
                        <TextBox Classes="code" Text="{Binding Notes}"
                                 Watermark="room, lecturer, reminders, anything…"
                                 AcceptsReturn="True" TextWrapping="Wrap" MinHeight="120" />
                    </StackPanel>
                </Border>
            </StackPanel>

            <!-- Study time: weekly goal vs actual focus -->
            <Border Classes="card" IsVisible="{Binding HasStudyGoal}">
                <StackPanel Spacing="8">
                    <TextBlock Text="勉強時間 · study time" Classes="jp" />
                    <ProgressBar Value="{Binding StudyGoalFraction}" Minimum="0" Maximum="1"
                                 Height="5" MinHeight="0"
                                 Foreground="{DynamicResource MatchaBrush}"
                                 Background="{DynamicResource SurfaceHoverBrush}" />
                    <TextBlock Text="{Binding StudyGoalLabel}" FontSize="13"
                               Classes.ggood="{Binding IsStudyGoalMet}" Classes="grade" />
                </StackPanel>
            </Border>

            <!-- Around the app: linked by course code -->
            <Border Classes="card">
                <StackPanel Spacing="6">
                    <TextBlock Text="関連 · around the app" Classes="jp" />
                    <TextBlock Text="{Binding LinkedTicketsLabel}" FontSize="13"
                               IsVisible="{Binding HasLinkedInfo}" />
                    <TextBlock Text="{Binding LinkedClassLabel}" FontSize="13"
                               Foreground="{DynamicResource BlueBrush}"
                               IsVisible="{Binding LinkedClassLabel, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />
                    <TextBlock Text="add a course code to link tickets and classes"
                               Classes="caption" IsVisible="{Binding HasNoCode}" />
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>

    <!-- Add / edit subject modal -->
    <Border Classes="modal-backdrop"
            IsVisible="{Binding IsModalOpen}"
            Background="#A0000000">
        <Border Classes="card modal-card"
                Width="420" Padding="22"
                HorizontalAlignment="Center" VerticalAlignment="Center"
                RenderTransformOrigin="0.5,0.5">
            <Border.RenderTransform>
                <ScaleTransform ScaleX="1" ScaleY="1" />
            </Border.RenderTransform>
            <StackPanel Spacing="12">
                <TextBlock Text="{Binding ModalTitle}" Classes="jp" />

                <TextBox Text="{Binding FormName}" Watermark="subject name" />

                <Grid ColumnDefinitions="*,8,110">
                    <AutoCompleteBox Grid.Column="0" Text="{Binding FormCode}"
                                     ItemsSource="{Binding KnownCourses}"
                                     FilterMode="Contains"
                                     Watermark="course code" />
                    <NumericUpDown Grid.Column="2" Value="{Binding FormCredits}"
                                   Watermark="credits"
                                   Minimum="0.5" Maximum="60" Increment="0.5" FormatString="0.#"
                                   ToolTip.Tip="weight toward the overall figure — credit hours / ects / units" />
                </Grid>

                <Grid ColumnDefinitions="*,8,*,8,*">
                    <NumericUpDown Grid.Column="0" Value="{Binding FormYear}"
                                   Watermark="year" Minimum="1" Maximum="10" FormatString="0" />
                    <NumericUpDown Grid.Column="2" Value="{Binding FormSemester}"
                                   Watermark="semester" Minimum="1" Maximum="4" FormatString="0" />
                    <NumericUpDown Grid.Column="4" Value="{Binding FormTarget}"
                                   Watermark="target %" Minimum="1" Maximum="100" FormatString="0.#"
                                   ToolTip.Tip="the grade you're aiming for — drives the outlook" />
                </Grid>

                <NumericUpDown Value="{Binding FormTargetHours}"
                               Watermark="study goal — hours / week"
                               Minimum="0" Maximum="80" Increment="0.5" FormatString="0.#"
                               ToolTip.Tip="weekly study-time goal — tracked against your focus minutes" />

                <TextBox Text="{Binding FormDropRules}"
                         Watermark="drop rules — e.g. quiz: best 8; lab: best 3"
                         ToolTip.Tip="per category, only the best N count" />

                <Grid ColumnDefinitions="*,*" Margin="0,4,0,0">
                    <Button Grid.Column="0" Content="cancel"
                            HorizontalAlignment="Stretch"
                            Command="{Binding CancelModalCommand}" />
                    <Button Grid.Column="1" Content="{Binding ModalAction}" Classes="accent"
                            HorizontalAlignment="Stretch" Margin="8,0,0,0"
                            Command="{Binding ConfirmModalCommand}" />
                </Grid>
            </StackPanel>
        </Border>
    </Border>

    </Grid>
</UserControl>
