<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Tomoshibi.ViewModels"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             x:Class="Tomoshibi.Views.ShopView"
             x:DataType="vm:ShopViewModel">

    <Grid RowDefinitions="Auto,*" Margin="28,4,28,28" MaxWidth="{StaticResource PageMaxWidth}">

        <!-- Header with balance -->
        <Grid Grid.Row="0" ColumnDefinitions="*,Auto" Margin="0,0,0,16">
            <StackPanel Spacing="3">
                <TextBlock Classes="path" Text="~/tomoshibi/shop" />
                <StackPanel Orientation="Horizontal" Spacing="10">
                    <TextBlock Text="❯" Classes="prompt" />
                    <TextBlock Text="{Binding Wallet.BalanceLabel}" Classes="h1 cjk" VerticalAlignment="Center" />
                </StackPanel>
                <TextBlock Text="earn 火種 embers by focusing — one per minute"
                           Classes="caption" Margin="0,2,0,0" />
                <TextBlock Text="{Binding Flash}" Classes="caption"
                           Foreground="{DynamicResource MatchaBrush}"
                           IsVisible="{Binding Flash, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />
            </StackPanel>
        </Grid>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel Spacing="4">
                <TextBlock Text="// テーマ · themes" Classes="jp" Margin="2,0,0,8" />

                <ItemsControl ItemsSource="{Binding Themes}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="vm:ShopThemeViewModel">
                            <Border Classes="card" Margin="0,0,0,12" Padding="16,14">
                                <Grid ColumnDefinitions="Auto,*,Auto,Auto">

                                    <!-- Swatch: a tiny mock card -->
                                    <Border Grid.Column="0" Width="56" Height="40"
                                            CornerRadius="6" Background="{Binding SwatchBg}"
                                            VerticalAlignment="Center">
                                        <Border Width="40" Height="22" CornerRadius="4"
                                                Background="{Binding SwatchCard}"
                                                VerticalAlignment="Center" HorizontalAlignment="Center">
                                            <StackPanel Orientation="Horizontal" Spacing="3"
                                                        VerticalAlignment="Center" HorizontalAlignment="Center">
                                                <Ellipse Width="7" Height="7" Fill="{Binding SwatchAccent}" />
                                                <Rectangle Width="14" Height="3" RadiusX="1.5" RadiusY="1.5"
                                                           Fill="{Binding SwatchText}" VerticalAlignment="Center" />
                                            </StackPanel>
                                        </Border>
                                    </Border>

                                    <StackPanel Grid.Column="1" Spacing="2" VerticalAlignment="Center"
                                                Margin="14,0,0,0">
                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                            <TextBlock Text="{Binding Jp}" FontWeight="SemiBold" />
                                            <TextBlock Text="{Binding En}" Classes="caption"
                                                       VerticalAlignment="Center" />
                                        </StackPanel>
                                        <TextBlock Text="{Binding PriceLabel}" Classes="caption"
                                                   Foreground="{DynamicResource AmberBrush}" />
                                    </StackPanel>

                                    <TextBlock Grid.Column="2" Text="✓ owned" Classes="caption"
                                               VerticalAlignment="Center" Margin="0,0,10,0"
                                               IsVisible="{Binding IsOwned}" />

                                    <Button Grid.Column="3" Classes="accent"
                                            Content="{Binding ActionLabel}"
                                            IsEnabled="{Binding ActionEnabled}"
                                            Command="{Binding $parent[ItemsControl].((vm:ShopViewModel)DataContext).ActivateCommand}"
                                            CommandParameter="{Binding}" />
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <TextBlock Text="more to come — icon packs, sounds…" Classes="caption"
                           Margin="2,4,0,0" />
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
